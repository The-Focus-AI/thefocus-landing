  { model: "maestro-reasoning", provider: "Arcee", answer: "unclear", correctReason: false, quality: 1, timeS: 0.9, cost: 0, stated: "N/A", thinking: true, family: "Other", local: false },
  { model: "kimi-k2-thinking", provider: "Moonshot", answer: "unclear", correctReason: false, quality: 1, timeS: 0.7, cost: 0.00003854, stated: "N/A", thinking: true, family: "Kimi", local: false },
  { model: "gpt-5.2-pro", provider: "OpenAI", answer: "unclear", correctReason: false, quality: 1, timeS: 0.6, cost: 0, stated: "N/A", thinking: false, family: "GPT", local: false },
  { model: "o1-pro", provider: "OpenAI", answer: "unclear", correctReason: false, quality: 1, timeS: 0.4, cost: 0, stated: "N/A", thinking: true, family: "GPT", local: false }
];


// Derive categories
DATA.forEach(d => {
  if (d.answer === 'drive' && d.correctReason) d.category = 'correct';
  else if (d.answer === 'drive' && !d.correctReason) d.category = 'lucky';
  else if (d.answer === 'walk') d.category = 'fail';
  else d.category = 'other';
});

// TABLE
const tbody = document.getElementById('tableBody');
let currentFilter = 'all';
let sortCol = 'quality';
let sortAsc = false;

function renderTable() {
  let filtered = currentFilter === 'all' ? DATA :
    currentFilter === 'local' ? DATA.filter(d => d.local) :
    DATA.filter(d => d.category === currentFilter);
  const search = document.getElementById('searchInput').value.toLowerCase();
  if (search) filtered = filtered.filter(d => d.model.toLowerCase().includes(search) || d.provider.toLowerCase().includes(search) || d.family.toLowerCase().includes(search));

  filtered.sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (typeof va === 'string') { va = va.toLowerCase(); vb = vb.toLowerCase(); }
    if (va < vb) return sortAsc ? -1 : 1;
    if (va > vb) return sortAsc ? 1 : -1;
    return 0;
  });

  tbody.innerHTML = filtered.map(d => {
    const catClass = `cat-${d.category}`;
    const badge = `badge-${d.answer}`;
    const reasonStr = d.correctReason ? '&#10003;' : '&#10007;';
    const reasonColor = d.correctReason ? 'color:var(--green)' : 'color:var(--red)';
    const qualityHtml = Array.from({length:5}, (_,i) => {
      const cls = i < d.quality ? (d.quality >= 4 ? 'filled' : d.quality >= 2 ? 'filled-low' : 'filled-fail') : '';
      return `<span class="${cls}"></span>`;
    }).join('');
    const costStr = d.cost > 0 ? `$${d.cost.toFixed(6)}` : 'free';
    const timeStr = d.timeS > 0 ? `${d.timeS.toFixed(1)}s` : '-';
    const thinkBadge = d.thinking ? '<span class="thinking-badge">THINKING</span>' : '';
    const localBadge = d.local ? '<span class="local-badge">LOCAL</span>' : '';

    return `<tr class="${catClass}">
      <td>${d.model}${thinkBadge}${localBadge}</td>
      <td>${d.provider}</td>
      <td><span class="badge ${badge}">${d.answer}</span></td>
      <td style="${reasonColor};font-weight:600;text-align:center">${reasonStr}</td>
      <td><div class="quality-bar">${qualityHtml}</div></td>
      <td class="time-cell">${timeStr}</td>
      <td class="cost-cell">${costStr}</td>
      <td class="reason-cell" title="${d.stated}">${d.stated}</td>
    </tr>`;
  }).join('');
}

// Sort
document.querySelectorAll('th[data-col]').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    const colMap = { model:'model', provider:'provider', answer:'answer', reason:'correctReason', quality:'quality', time:'timeS', cost:'cost', stated:'stated' };
    const mapped = colMap[col];
    if (sortCol === mapped) sortAsc = !sortAsc;
    else { sortCol = mapped; sortAsc = col === 'model' || col === 'provider'; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted'));
    th.classList.add('sorted');
    th.querySelector('.sort-arrow').textContent = sortAsc ? '\u25B2' : '\u25BC';
    renderTable();
  });
});

// Filters
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentFilter = btn.dataset.filter;
    renderTable();
  });
});

document.getElementById('searchInput').addEventListener('input', renderTable);
renderTable();

// CHARTS
const COLORS = { correct: '#1a7a4c', lucky: '#b8860b', fail: '#c0392b', other: '#95a5a6' };

Chart.defaults.font.family = "'DM Sans', sans-serif";
Chart.defaults.font.size = 12;
Chart.defaults.color = '#6b6358';

// Family Chart
const families = [...new Set(DATA.map(d => d.family))].sort();
const familyCounts = families.map(f => {
  const models = DATA.filter(d => d.family === f);
  return {
    family: f,
    correct: models.filter(d => d.category === 'correct').length,
    lucky: models.filter(d => d.category === 'lucky').length,
    fail: models.filter(d => d.category === 'fail').length,
    other: models.filter(d => d.category === 'other').length,
    total: models.length
  };
}).sort((a,b) => (b.correct/b.total) - (a.correct/a.total));

new Chart(document.getElementById('familyChart'), {
  type: 'bar',
  data: {
    labels: familyCounts.map(f => `${f.family} (${f.total})`),
    datasets: [
      { label: 'Correct', data: familyCounts.map(f => f.correct), backgroundColor: COLORS.correct },
      { label: 'Lucky', data: familyCounts.map(f => f.lucky), backgroundColor: COLORS.lucky },
      { label: 'Failed', data: familyCounts.map(f => f.fail), backgroundColor: COLORS.fail },
      { label: 'Other', data: familyCounts.map(f => f.other), backgroundColor: COLORS.other },
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    scales: { x: { stacked: true }, y: { stacked: true, title: { display: true, text: 'Number of Models' } } },
    plugins: { legend: { position: 'bottom' } }
  }
});

// Cost Chart
const costData = DATA.filter(d => d.cost > 0);
new Chart(document.getElementById('costChart'), {
  type: 'scatter',
  data: {
    datasets: [
      { label: 'Correct', data: costData.filter(d=>d.category==='correct').map(d=>({x:d.cost*1000,y:d.quality,label:d.model})), backgroundColor: COLORS.correct, pointRadius: 6 },
      { label: 'Lucky', data: costData.filter(d=>d.category==='lucky').map(d=>({x:d.cost*1000,y:d.quality,label:d.model})), backgroundColor: COLORS.lucky, pointRadius: 6 },
      { label: 'Failed', data: costData.filter(d=>d.category==='fail').map(d=>({x:d.cost*1000,y:d.quality,label:d.model})), backgroundColor: COLORS.fail, pointRadius: 5, pointStyle: 'cross' },
      { label: 'Other', data: costData.filter(d=>d.category==='other').map(d=>({x:d.cost*1000,y:d.quality,label:d.model})), backgroundColor: COLORS.other, pointRadius: 5, pointStyle: 'triangle' },
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    scales: {
      x: { type: 'logarithmic', title: { display: true, text: 'Cost per Query (millicents)' },
        ticks: { callback: v => `$${(v/1000).toFixed(4)}` }
      },
      y: { title: { display: true, text: 'Reasoning Quality' }, min: 0, max: 6 }
    },
    plugins: {
      legend: { position: 'bottom' },
      tooltip: { callbacks: { label: ctx => `${ctx.raw.label}: $${(ctx.raw.x/1000).toFixed(6)}` } }
    }
  }
});

// Time Chart
const categories = ['correct','lucky','fail','other'];
const catLabels = ['Correct','Lucky','Failed','Other'];
const catColors = [COLORS.correct, COLORS.lucky, COLORS.fail, COLORS.other];

new Chart(document.getElementById('timeChart'), {
  type: 'bar',
  data: {
    labels: catLabels,
    datasets: [{
      label: 'Avg Response Time (s)',
      data: categories.map(cat => {
        const times = DATA.filter(d => d.category === cat && d.timeS > 0).map(d => d.timeS);
        return times.length ? (times.reduce((a,b)=>a+b,0)/times.length).toFixed(1) : 0;
      }),
      backgroundColor: catColors.map(c => c + 'cc'),
      borderColor: catColors,
      borderWidth: 1
    }, {
      label: 'Median Response Time (s)',
      data: categories.map(cat => {
        const times = DATA.filter(d => d.category === cat && d.timeS > 0).map(d => d.timeS).sort((a,b)=>a-b);
        if (!times.length) return 0;
        const mid = Math.floor(times.length/2);
        return times.length % 2 ? times[mid].toFixed(1) : ((times[mid-1]+times[mid])/2).toFixed(1);
      }),
      backgroundColor: catColors.map(c => c + '55'),
      borderColor: catColors,
      borderWidth: 1,
      borderDash: [3, 3]
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    scales: { y: { title: { display: true, text: 'Seconds' } } },
    plugins: { legend: { position: 'bottom' } }
  }
});

// Thinking Chart
const thinkingModels = DATA.filter(d => d.thinking);
const nonThinkingCorrectRate = DATA.filter(d => !d.thinking && d.category === 'correct').length / DATA.filter(d => !d.thinking).length;
const thinkingCorrectRate = thinkingModels.filter(d => d.category === 'correct').length / thinkingModels.length;

new Chart(document.getElementById('thinkingChart'), {
  type: 'bar',
  data: {
    labels: thinkingModels.map(d => d.model.replace(/-thinking/g,'').replace(':thinking','').replace('qwen3-','q3-').replace('qwen-plus','q-plus')),
    datasets: [{
      label: 'Reasoning Quality',
      data: thinkingModels.map(d => d.quality),
      backgroundColor: thinkingModels.map(d => d.category === 'correct' ? COLORS.correct : d.category === 'lucky' ? COLORS.lucky : COLORS.fail),
      borderWidth: 0,
    }]
  },
  options: {
    indexAxis: 'y',
    responsive: true, maintainAspectRatio: false,
    scales: { x: { min: 0, max: 5, title: { display: true, text: 'Quality Score' } } },
    plugins: {
      legend: { display: false },
      title: { display: true, text: `Thinking models: ${(thinkingCorrectRate*100).toFixed(0)}% correct vs ${(nonThinkingCorrectRate*100).toFixed(0)}% for standard models`, font: { size: 11, weight: 'normal' }, color: '#6b6358' }
    }
  }
});

// Local vs Cloud Chart
const cloudModels = DATA.filter(d => !d.local);
const localModels = DATA.filter(d => d.local);
const cloudCorrect = cloudModels.filter(d => d.category === 'correct').length;
const localCorrect = localModels.filter(d => d.category === 'correct').length;

new Chart(document.getElementById('localChart'), {
  type: 'bar',
  data: {
    labels: ['Cloud Models', 'Local (Ollama)'],
    datasets: [
      {
        label: 'Correct',
        data: [cloudCorrect, localCorrect],
        backgroundColor: COLORS.correct
      },
      {
        label: 'Lucky',
        data: [
          cloudModels.filter(d => d.category === 'lucky').length,
          localModels.filter(d => d.category === 'lucky').length
        ],
        backgroundColor: COLORS.lucky
      },
      {
        label: 'Failed',
        data: [
          cloudModels.filter(d => d.category === 'fail').length,
          localModels.filter(d => d.category === 'fail').length
        ],
        backgroundColor: COLORS.fail
      },
      {
        label: 'Other',
        data: [
          cloudModels.filter(d => d.category === 'other').length,
          localModels.filter(d => d.category === 'other').length
        ],
        backgroundColor: COLORS.other
      }
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    scales: { x: { stacked: true }, y: { stacked: true, title: { display: true, text: 'Number of Models' } } },
    plugins: {
      legend: { position: 'bottom' },
      title: { display: true, text: `Cloud: ${(cloudCorrect/cloudModels.length*100).toFixed(0)}% pass (${cloudCorrect}/${cloudModels.length}) | Local: ${(localCorrect/localModels.length*100).toFixed(0)}% pass (${localCorrect}/${localModels.length})`, font: { size: 11, weight: 'normal' }, color: '#6b6358' }
    }
  }
});
</script>

