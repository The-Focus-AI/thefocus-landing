// ============================================================
// Helpers
// ============================================================

function esc(s) {
  if (!s) return '';
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

function costStr(c) { return c > 0 ? '$' + c.toFixed(c < 0.01 ? 4 : c < 0.1 ? 3 : 2) : 'Free'; }

function timeStr(m) {
  if (m >= 60) return Math.round(m / 60) + 'h' + (m % 60 > 0 ? Math.round(m % 60) + 'm' : '');
  if (m >= 1) return Math.round(m) + 'm';
  return Math.round(m * 60) + 's';
}

function typeBadge(open) {
  return open ? '<span class="badge badge-open">open</span>' : '<span class="badge badge-closed">closed</span>';
}

function releasedLabel(r) {
  if (!r) return '';
  const [y, m] = r.split('-');
  const months = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return months[parseInt(m)] + ' ' + y.slice(2);
}

function providerBadge(p) {
  if (p === 'openrouter') return '<span class="badge badge-or">OR</span>';
  if (p === 'google') return '<span class="badge badge-google">Google</span>';
  if (p === 'deepinfra') return '<span class="badge badge-di">DI</span>';
  if (p === 'ollama') return '<span class="badge badge-local">Local</span>';
  return esc(p);
}

function freeBadge(d) {
  return d.cost === 0 ? ' <span class="badge badge-free">free</span>' : '';
}

function tierClass(pct) {
  if (pct >= 85) return 'tier-1';
  if (pct >= 80) return 'tier-2';
  if (pct >= 75) return 'tier-3';
  return 'tier-4';
}

function scoreClass(score, max) {
  const pct = score / max;
  if (pct >= 1.0) return 'score-cell score-perfect';
  if (pct >= 0.8) return 'score-cell score-good';
  if (pct >= 0.5) return 'score-cell score-mid';
  return 'score-cell score-low';
}

function modelHtml(m) {
  const i = m.indexOf('/');
  if (i > 0) return '<span class="provider-prefix">' + esc(m.slice(0, i + 1)) + '</span>' + esc(m.slice(i + 1));
  return esc(m);
}

// ============================================================
// Leaderboard
// ============================================================

let currentFilter = 'all';
let sortCol = 'rank';
let sortAsc = true;
let minScoreFilter = 0;
let maxCostFilter = Infinity;

function getVisible() {
  let list = [...MODELS];
  const q = document.getElementById('search').value.toLowerCase();
  if (q) list = list.filter(d => d.model.toLowerCase().includes(q) || d.provider.includes(q));
  if (currentFilter === 'openrouter') list = list.filter(d => d.provider === 'openrouter');
  if (currentFilter === 'google') list = list.filter(d => d.provider === 'google');
  if (currentFilter === 'deepinfra') list = list.filter(d => d.provider === 'deepinfra');
  if (currentFilter === 'ollama') list = list.filter(d => d.provider === 'ollama');
  if (currentFilter === 'free') list = list.filter(d => d.cost === 0);
  if (currentFilter === 'open') list = list.filter(d => d.open === true);
  if (currentFilter === 'closed') list = list.filter(d => d.open === false);
  if (minScoreFilter > 0) list = list.filter(d => d.combined >= minScoreFilter);
  if (maxCostFilter !== Infinity) list = list.filter(d => maxCostFilter === 0 ? d.cost === 0 : d.cost <= maxCostFilter || d.cost === 0);

  list.sort((a, b) => {
    let av, bv;
    switch (sortCol) {
      case 'model': av = a.model; bv = b.model; return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
      case 'provider': av = a.provider; bv = b.provider; return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
      case 'released': av = a.released; bv = b.released; return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
      case 'type': av = a.open ? 0 : 1; bv = b.open ? 0 : 1; break;
      case 'combined': av = a.combined; bv = b.combined; break;
      case 'reasoning': av = a.reasoning[0]; bv = b.reasoning[0]; break;
      case 'knowledge': av = a.knowledge[0]; bv = b.knowledge[0]; break;
      case 'instruction': av = a.instruction[0]; bv = b.instruction[0]; break;
      case 'coding': av = a.coding[0]; bv = b.coding[0]; break;
      case 'mcp': av = a.mcp[0] ?? -1; bv = b.mcp[0] ?? -1; break;
      case 'cost': av = a.cost || 9999; bv = b.cost || 9999; return sortAsc ? av - bv : bv - av;
      case 'time': av = a.timeMin; bv = b.timeMin; return sortAsc ? av - bv : bv - av;
      default: av = a.combined; bv = b.combined;
    }
    let d = sortAsc ? av - bv : bv - av;
    if (d === 0) d = a.timeMin - b.timeMin;
    return d;
  });
  return list;
}

function renderLeaderboard() {
  const list = getVisible();
  const shown = list.length;
  const total = MODELS.length;
  const summaryEl = document.getElementById('filter-summary');
  if (summaryEl) summaryEl.textContent = shown < total ? shown + ' of ' + total + ' models shown' : '';

  const tbody = document.getElementById('leaderboard-body');
  tbody.innerHTML = list.map((d, i) => {
    const rank = i + 1;
    const medal = rank <= 3 ? ['\ud83e\udd47', '\ud83e\udd48', '\ud83e\udd49'][rank - 1] : rank;
    return '<tr class="' + tierClass(d.combined) + '">' +
      '<td style="font-weight:700">' + medal + '</td>' +
      '<td class="model-cell">' + modelHtml(d.model) + '</td>' +
      '<td>' + providerBadge(d.provider) + freeBadge(d) + '</td>' +
      '<td class="released-cell">' + releasedLabel(d.released) + '</td>' +
      '<td>' + typeBadge(d.open) + '</td>' +
      '<td class="combined-cell">' + d.combined + '%</td>' +
      '<td class="' + scoreClass(d.reasoning[0], d.reasoning[1]) + '">' + d.reasoning[0] + '/' + d.reasoning[1] + '</td>' +
      '<td class="' + scoreClass(d.knowledge[0], d.knowledge[1]) + '">' + d.knowledge[0] + '/' + d.knowledge[1] + '</td>' +
      '<td class="' + scoreClass(d.instruction[0], d.instruction[1]) + '">' + d.instruction[0] + '/' + d.instruction[1] + '</td>' +
      '<td class="' + scoreClass(d.coding[0], d.coding[1]) + '">' + d.coding[0] + '/' + d.coding[1] + '</td>' +
      '<td class="' + (d.mcp[0] !== null ? scoreClass(d.mcp[0], d.mcp[1]) : 'score-cell') + '">' + (d.mcp[0] !== null ? d.mcp[0] + '/' + d.mcp[1] : '&mdash;') + '</td>' +
      '<td class="cost-cell">' + costStr(d.cost) + '</td>' +
      '<td class="time-cell">' + timeStr(d.timeMin) + '</td>' +
      '</tr>';
  }).join('');
}

function setFilter(f) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.f === f));
  renderLeaderboard();
}

function sortBy(col) {
  if (sortCol === col) sortAsc = !sortAsc;
  else { sortCol = col; sortAsc = col === 'model' || col === 'provider' || col === 'released' || col === 'time' || col === 'cost'; }
  renderLeaderboard();
}

function updateFilters() {
  const scoreSlider = document.getElementById('filter-score');
  const costSlider = document.getElementById('filter-cost');

  minScoreFilter = parseInt(scoreSlider.value);
  document.getElementById('filter-score-val').textContent = minScoreFilter === 0 ? 'any' : minScoreFilter + '%';

  const costPct = parseInt(costSlider.value);
  if (costPct >= 100) {
    maxCostFilter = Infinity;
    document.getElementById('filter-cost-val').textContent = 'any';
  } else if (costPct === 0) {
    maxCostFilter = 0;
    document.getElementById('filter-cost-val').textContent = 'free';
  } else {
    maxCostFilter = Math.pow(costPct / 100, 2) * 0.5;
    document.getElementById('filter-cost-val').textContent = '$' + maxCostFilter.toFixed(3);
  }

  renderLeaderboard();
}

// ============================================================
// Pending Models Table
// ============================================================

function renderPending() {
  const tbody = document.getElementById('pending-body');
  if (!tbody) return;
  tbody.innerHTML = PENDING_MODELS.map(d => {
    return '<tr>' +
      '<td class="model-cell">' + modelHtml(d.model) + '</td>' +
      '<td>' + providerBadge(d.provider) + '</td>' +
      '<td class="released-cell">' + releasedLabel(d.released) + '</td>' +
      '<td>' + typeBadge(d.open) + '</td>' +
      '<td>' + esc(d.costPerMTok) + '</td>' +
      '</tr>';
  }).join('');
}

// ============================================================
// Cipher Table
// ============================================================

let cipherSort = 'c-time';
let cipherAsc = true;

function renderCipher() {
  let list = [...CIPHER_DATA];
  list.sort((a, b) => {
    let av, bv;
    switch (cipherSort) {
      case 'c-model': return cipherAsc ? a.model.localeCompare(b.model) : b.model.localeCompare(a.model);
      case 'c-score': av = a.score; bv = b.score; break;
      case 'c-time': av = a.timeSec; bv = b.timeSec; return cipherAsc ? av - bv : bv - av;
      default: av = a.timeSec; bv = b.timeSec; return av - bv;
    }
    let d = cipherAsc ? av - bv : bv - av;
    if (d === 0) d = a.timeSec - b.timeSec;
    return d;
  });

  document.getElementById('cipher-body').innerHTML = list.map(d => {
    const tc = d.score >= 7 ? 'tier-1' : d.score >= 5 ? 'tier-3' : 'tier-4';
    const timeLabel = d.timeSec >= 600 ? 'error' : d.timeSec >= 60 ? (d.timeSec / 60).toFixed(1) + 'm' : d.timeSec + 's';
    return '<tr class="' + tc + '">' +
      '<td class="model-cell">' + modelHtml(d.model) + '</td>' +
      '<td class="' + scoreClass(d.score, d.max) + '">' + d.score + '/' + d.max + '</td>' +
      '<td class="time-cell">' + timeLabel + '</td>' +
      '</tr>';
  }).join('');
}

// ============================================================
// MCP Table
// ============================================================

let mcpSort = 'm-total';
let mcpAsc = false;

function renderMCP() {
  let list = [...MCP_DATA];
  list.sort((a, b) => {
    let av, bv;
    switch (mcpSort) {
      case 'm-model': return mcpAsc ? a.model.localeCompare(b.model) : b.model.localeCompare(a.model);
      case 'm-tool': av = a.tool[0]; bv = b.tool[0]; break;
      case 'm-judge': av = a.judge[0]; bv = b.judge[0]; break;
      case 'm-total': av = a.total[0]; bv = b.total[0]; break;
      case 'm-time': av = a.timeSec; bv = b.timeSec; return mcpAsc ? av - bv : bv - av;
      case 'm-cost': av = a.cost || 9999; bv = b.cost || 9999; return mcpAsc ? av - bv : bv - av;
      default: av = a.total[0]; bv = b.total[0];
    }
    let d = mcpAsc ? av - bv : bv - av;
    if (d === 0) d = a.timeSec - b.timeSec;
    return d;
  });

  document.getElementById('mcp-body').innerHTML = list.map(d => {
    const tc = d.total[0] >= 11 ? 'tier-1' : d.total[0] >= 8 ? 'tier-2' : d.total[0] >= 6 ? 'tier-3' : 'tier-4';
    const clickable = d.key ? ' style="cursor:pointer" data-mcp-key="' + d.key + '"' : '';
    const active = d.key && d.key === mcpCurrentKey ? ' class="' + tc + ' mcp-active-row"' : ' class="' + tc + '"';
    return '<tr' + active + clickable + '>' +
      '<td class="model-cell">' + modelHtml(d.model) + '</td>' +
      '<td class="' + scoreClass(d.tool[0], d.tool[1]) + '">' + d.tool[0] + '/' + d.tool[1] + '</td>' +
      '<td class="score-cell">' + d.judge[0] + '/' + d.judge[1] + '</td>' +
      '<td><strong>' + d.total[0] + '</strong>/' + d.total[1] + '</td>' +
      '<td class="time-cell">' + (d.timeSec >= 60 ? Math.round(d.timeSec / 60) + 'm' : d.timeSec + 's') + '</td>' +
      '<td class="cost-cell">' + costStr(d.cost) + '</td>' +
      '</tr>';
  }).join('');
}

// ============================================================
// MCP Detail Panel
// ============================================================

const MCP_DETAIL_BASE = '/reports/model-showdown/details';
const mcpDetailCache = {};
let mcpCurrentKey = null;
let mcpCurrentIdx = -1;

async function loadMcpDetail(key) {
  if (mcpDetailCache[key]) return mcpDetailCache[key];
  try {
    const r = await fetch(MCP_DETAIL_BASE + '/' + key + '.json');
    const d = await r.json();
    mcpDetailCache[key] = d;
    return d;
  } catch (e) {
    return null;
  }
}

async function showMcpDetail(key) {
  mcpCurrentIdx = MCP_DATA.findIndex(d => d.key === key);
  if (mcpCurrentIdx < 0) return;
  mcpCurrentKey = key;
  const d = MCP_DATA[mcpCurrentIdx];

  document.getElementById('mcp-detail-title').textContent = d.model;
  document.getElementById('mcp-detail-subtitle').textContent = '';

  document.getElementById('mcp-detail-stats').innerHTML = [
    {k:'Total', v: d.total[0]+'/'+d.total[1]},
    {k:'Tool Score', v: d.tool[0]+'/'+d.tool[1]},
    {k:'Judge Score', v: d.judge[0]+'/'+d.judge[1]},
    {k:'Time', v: d.timeSec >= 60 ? Math.round(d.timeSec/60)+'m' : d.timeSec+'s'},
    {k:'Cost', v: costStr(d.cost)},
  ].map(s => '<div class="detail-stat"><div class="k">'+s.k+'</div><div class="v">'+s.v+'</div></div>').join('');

  document.getElementById('mcp-rendered-response').innerHTML = '<p class="loading">Loading response...</p>';
  document.getElementById('mcp-thread-view').innerHTML = '<p class="loading">Loading tool calls...</p>';
  document.getElementById('mcp-judge-view').innerHTML = '';

  document.getElementById('mcp-prev-btn').disabled = mcpCurrentIdx <= 0 || !MCP_DATA[mcpCurrentIdx - 1].key;
  document.getElementById('mcp-next-btn').disabled = mcpCurrentIdx >= MCP_DATA.length - 1 || !MCP_DATA[mcpCurrentIdx + 1].key;

  document.getElementById('mcp-detail-panel').classList.add('open');
  switchMcpTab('response');
  renderMCP();
  document.getElementById('mcp-detail-panel').scrollIntoView({ behavior: 'smooth', block: 'nearest' });

  const detail = await loadMcpDetail(key);
  if (mcpCurrentKey !== key) return;

  if (detail && detail.responseText) {
    document.getElementById('mcp-rendered-response').innerHTML = marked.parse(detail.responseText);
  } else {
    document.getElementById('mcp-rendered-response').innerHTML = '<p class="loading">No response text available.</p>';
  }

  if (detail) {
    renderMcpThread(detail.toolUsage);
    renderMcpJudge(detail);
    if (detail.judge && detail.judge.explanation) {
      document.getElementById('mcp-detail-subtitle').textContent = detail.judge.explanation.slice(0, 120) + (detail.judge.explanation.length > 120 ? '...' : '');
    }
  }
}

function renderMcpThread(toolUsage) {
  const el = document.getElementById('mcp-thread-view');
  if (!toolUsage || !toolUsage.calls || toolUsage.calls.length === 0) {
    el.innerHTML = '<p class="loading">No tool call data available.</p>';
    return;
  }
  let html = '';

  // Tool score breakdown
  if (toolUsage.tool_score_breakdown) {
    html += '<div class="thread-msg" style="background:var(--bg-alt);padding:1rem 1.5rem;margin-bottom:1.5rem">' +
      '<div class="msg-role">Tool Score: ' + toolUsage.tool_score + '/6</div>' +
      '<div style="font-size:0.85rem;color:var(--ink-light);white-space:pre-wrap">' + esc(toolUsage.tool_score_breakdown) + '</div></div>';
  }

  // Tool checklist
  const checks = [
    ['list_vehicles', toolUsage.called_list_vehicles],
    ['get_battery_health', toolUsage.called_get_battery_health],
    ['get_charges or get_charge_report', toolUsage.called_get_charges_or_report],
    ['get_efficiency', toolUsage.called_get_efficiency],
    ['get_my_chargers', toolUsage.called_get_my_chargers],
    ['search/find chargers', toolUsage.called_search_or_find_chargers],
  ];
  html += '<div class="thread-msg" style="background:#f0f4f8;border:1px solid #c8d6e5;padding:1rem 1.5rem;margin-bottom:1.5rem">' +
    '<div class="msg-role">Required Tool Calls</div>' +
    checks.map(([name, ok]) => '<div style="padding:0.3rem 0;font-size:0.9rem">' +
      (ok ? '\u2705' : '\u274c') + ' <code style="font-size:0.85em">' + name + '</code></div>').join('') +
    '</div>';

  // Individual calls
  for (let i = 0; i < toolUsage.calls.length; i++) {
    const call = toolUsage.calls[i];
    const args = call.args ? JSON.stringify(call.args, null, 2) : '';
    html += '<div class="thread-msg tool-call"><div class="msg-role">Step ' + (i + 1) + ' &mdash; Tool Call</div>' +
      '<div class="tool-name">' + esc(call.name) + '</div>' +
      (args && args !== '{}' ? '<pre class="tool-args">' + esc(args) + '</pre>' : '') + '</div>';
  }

  el.innerHTML = html;
}

function renderMcpJudge(detail) {
  const el = document.getElementById('mcp-judge-view');
  if (!detail.judge) {
    el.innerHTML = '<p class="loading">No judge data available.</p>';
    return;
  }
  const j = detail.judge;
  let html = '<h3 style="margin-bottom:1rem">Judge Verdict</h3>';

  html += '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin:1.5rem 0">';
  html += '<div style="background:var(--bg-alt);padding:1rem;border-radius:4px"><div style="font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;color:var(--ink-faint)">Data Synthesis</div><div style="font-family:var(--serif);font-size:2rem;margin-top:0.2rem">' + j.data_synthesis + '<span style="font-size:1rem;color:var(--ink-faint)">/5</span></div></div>';
  html += '<div style="background:var(--bg-alt);padding:1rem;border-radius:4px"><div style="font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;color:var(--ink-faint)">Actionable Insights</div><div style="font-family:var(--serif);font-size:2rem;margin-top:0.2rem">' + j.actionable_insights + '<span style="font-size:1rem;color:var(--ink-faint)">/5</span></div></div>';
  html += '<div style="background:var(--bg-alt);padding:1rem;border-radius:4px"><div style="font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;color:var(--ink-faint)">Factual Grounding</div><div style="font-family:var(--serif);font-size:2rem;margin-top:0.2rem">' + j.factual_grounding + '<span style="font-size:1rem;color:var(--ink-faint)">/5</span></div></div>';
  html += '</div>';

  html += '<div style="background:var(--bg-alt);padding:1rem;border-radius:4px;margin-bottom:1rem"><div style="font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;color:var(--ink-faint)">Overall Score</div><div style="font-family:var(--serif);font-size:2.5rem;margin-top:0.2rem">' + j.overall_score + '<span style="font-size:1.2rem;color:var(--ink-faint)">/10</span></div></div>';

  if (j.explanation) {
    html += '<p style="color:var(--ink-light);font-size:0.9rem;max-width:600px"><strong>Explanation:</strong> ' + esc(j.explanation) + '</p>';
  }

  // Token/cost info
  if (detail.tokens) {
    html += '<div style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--border)">';
    html += '<div style="font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;color:var(--ink-faint);margin-bottom:0.5rem">Token Usage</div>';
    html += '<div style="font-size:0.85rem;color:var(--ink-light)">';
    html += 'Prompt: ' + (detail.tokens.promptTokens || 0).toLocaleString() + ' &middot; ';
    html += 'Completion: ' + (detail.tokens.completionTokens || 0).toLocaleString() + ' &middot; ';
    html += 'Total: ' + (detail.tokens.total || 0).toLocaleString();
    html += '</div></div>';
  }

  el.innerHTML = html;
}

function switchMcpTab(name) {
  document.querySelectorAll('#mcp-detail-panel .detail-tab').forEach(t => t.classList.toggle('active', t.dataset.mcpTab === name));
  document.querySelectorAll('.mcp-tab-content').forEach(t => t.classList.remove('active'));
  document.getElementById('mcp-tab-' + name).classList.add('active');
}

function navMcpModel(dir) {
  let next = mcpCurrentIdx + dir;
  while (next >= 0 && next < MCP_DATA.length && !MCP_DATA[next].key) next += dir;
  if (next >= 0 && next < MCP_DATA.length && MCP_DATA[next].key) showMcpDetail(MCP_DATA[next].key);
}

function closeMcpDetail() {
  document.getElementById('mcp-detail-panel').classList.remove('open');
  mcpCurrentKey = null;
  mcpCurrentIdx = -1;
  renderMCP();
}

// ============================================================
// Speed Table
// ============================================================

let speedSort = 'sq-score';
let speedAsc = false;

function renderSpeed() {
  let list = [...SPEED_DATA];
  list.sort((a, b) => {
    let av, bv;
    switch (speedSort) {
      case 'sq-model': return speedAsc ? a.model.localeCompare(b.model) : b.model.localeCompare(a.model);
      case 'sq-score': av = a.score; bv = b.score; break;
      case 'sq-time': av = a.timeMin; bv = b.timeMin; return speedAsc ? av - bv : bv - av;
      default: av = a.score; bv = b.score;
    }
    return speedAsc ? av - bv : bv - av;
  });

  document.getElementById('speed-body').innerHTML = list.map(d => {
    return '<tr' + (d.highlight ? ' class="tier-1"' : '') + '>' +
      '<td class="model-cell">' + modelHtml(d.model) + '</td>' +
      '<td class="combined-cell">' + d.score + '%</td>' +
      '<td class="time-cell">' + timeStr(d.timeMin) + '</td>' +
      '<td>' + (d.highlight ? '<strong>' + d.spot + '</strong>' : d.spot) + '</td>' +
      '</tr>';
  }).join('');
}

// ============================================================
// Event Listeners
// ============================================================

document.addEventListener('DOMContentLoaded', () => {
  // Initial render
  renderLeaderboard();
  renderPending();
  renderCipher();
  renderMCP();
  renderSpeed();

  // Filter buttons
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => setFilter(btn.dataset.f));
  });

  // Range filters
  document.getElementById('filter-score')?.addEventListener('input', updateFilters);
  document.getElementById('filter-cost')?.addEventListener('input', updateFilters);

  // Search input
  document.getElementById('search')?.addEventListener('input', renderLeaderboard);

  // MCP detail panel — row clicks
  document.getElementById('mcp-body').addEventListener('click', (e) => {
    const row = e.target.closest('tr[data-mcp-key]');
    if (row) showMcpDetail(row.dataset.mcpKey);
  });

  // MCP detail panel — tabs
  document.querySelectorAll('#mcp-detail-panel .detail-tab').forEach(tab => {
    tab.addEventListener('click', () => switchMcpTab(tab.dataset.mcpTab));
  });

  // MCP detail panel — nav and close
  document.getElementById('mcp-prev-btn').addEventListener('click', () => navMcpModel(-1));
  document.getElementById('mcp-next-btn').addEventListener('click', () => navMcpModel(1));
  document.getElementById('mcp-close-btn').addEventListener('click', closeMcpDetail);

  // Sort headers — delegate by data-sort attribute
  document.querySelectorAll('th[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort;
      // Leaderboard columns
      if (['rank', 'model', 'provider', 'released', 'type', 'combined', 'reasoning', 'knowledge', 'instruction', 'coding', 'mcp', 'cost', 'time'].includes(col)) {
        sortBy(col);
      }
      // Cipher columns
      if (col.startsWith('c-')) {
        if (cipherSort === col) cipherAsc = !cipherAsc;
        else { cipherSort = col; cipherAsc = col === 'c-model' || col === 'c-time'; }
        renderCipher();
      }
      // MCP columns
      if (col.startsWith('m-')) {
        if (mcpSort === col) mcpAsc = !mcpAsc;
        else { mcpSort = col; mcpAsc = col === 'm-model' || col === 'm-time' || col === 'm-cost'; }
        renderMCP();
      }
      // Speed columns
      if (col.startsWith('sq-')) {
        if (speedSort === col) speedAsc = !speedAsc;
        else { speedSort = col; speedAsc = col === 'sq-model' || col === 'sq-time'; }
        renderSpeed();
      }
    });
  });
});
</script>

</BaseLayout>
