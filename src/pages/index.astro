---
import BaseLayout from "../layout/BaseLayout.astro";
---

<BaseLayout
  pageTitle="TheFocus.AI | Building an Intelligent Organization"
  bigHeader={true}
  description="AI capabilities are arriving faster than organizations can absorb them. We help organizations move from tribal knowledge to structured intelligence — production AI in weeks, not quarters."
  showOrganizationSchema={true}
  category="home"
>
  <!-- Hero Section -->
  <section class="py-12 md:py-24 relative overflow-visible">
    <!-- Ambient background shapes that connect illustration to page -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 right-[15%] w-16 h-16 md:w-24 md:h-24 rounded-full bg-vermilion/5 animate-pulse" style="animation-duration: 8s;"></div>
      <div class="absolute bottom-20 left-[10%] w-12 h-12 md:w-20 md:h-20 rounded-full bg-petrol/5 animate-pulse" style="animation-duration: 10s;"></div>
      <div class="absolute top-1/3 left-[5%] w-8 h-8 md:w-14 md:h-14 rounded-full bg-vermilion/5 animate-pulse" style="animation-duration: 7s;"></div>
    </div>
    
    <div class="max-w-4xl mx-auto relative">
      <div class="max-w-2xl">
        <h1 class="font-sans text-[2.5rem] leading-[1.1] sm:text-5xl md:text-7xl font-bold text-ink mb-8 md:mb-10">
          Production AI, Shipped in Weeks
        </h1>
        <p class="text-xl md:text-2xl text-graphite leading-[1.6] mb-6">
          We help growth-stage companies go from tribal knowledge to production AI systems — fast. <strong class="text-ink">Every engagement is principal-led. You work directly with the people who build.</strong> Not pilots. Not proofs of concept. Production, in weeks.
        </p>
        <p class="text-sm uppercase tracking-widest text-petrol mb-10 md:mb-12 font-medium">For founders, CEOs, and product leaders at growth-stage companies</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="mailto:hey@thefocus.ai?subject=Assessment%20%26%20Roadmap"
            class="inline-block px-8 py-4 bg-petrol text-paper font-medium uppercase text-sm tracking-wider rounded-full hover:bg-petrol/90 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 text-center"
          >
            Get Your AI Roadmap
          </a>
          <a
            href="/case-studies"
            class="inline-block px-8 py-4 border-2 border-ink/20 text-ink font-medium uppercase text-sm tracking-wider rounded-full hover:border-petrol hover:text-petrol hover:-translate-y-0.5 transition-all duration-200 text-center"
          >
            See How We've Delivered
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-ink">
    <div class="max-w-screen-xl mx-auto px-5 md:px-8 py-16 md:py-20">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol-light mb-8 font-medium text-center">Results</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 max-w-4xl mx-auto">
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-bold text-paper mb-2">27%</p>
          <p class="text-sm text-paper/60">higher conversion</p>
        </div>
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-bold text-paper mb-2">78%</p>
          <p class="text-sm text-paper/60">faster decisions</p>
        </div>
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-bold text-paper mb-2">50M+</p>
          <p class="text-sm text-paper/60">devices reached</p>
        </div>
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-bold text-paper mb-2">8 wks</p>
          <p class="text-sm text-paper/60">to production</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Trophy Wall Section -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen">
    <div class="max-w-screen-xl mx-auto px-5 md:px-8 py-16 md:py-24 text-center">
      <!-- Decorative line -->
      <div class="w-12 h-1 bg-petrol/30 mb-6 mx-auto"></div>
      
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-6 font-medium">
        Our Clients
      </p>
      <h2 class="font-sans text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-ink mb-5 max-w-4xl leading-tight mx-auto">
        Trusted by industry leaders to deliver AI that performs
      </h2>
      <p class="text-lg md:text-xl text-graphite mb-12 max-w-2xl leading-relaxed mx-auto">
        Samsung, Tesla, Perplexity, Rivian, Con Edison. We've shipped <a href="/capabilities" class="text-petrol underline underline-offset-2 hover:text-petrol/80 transition-colors">production AI systems</a> for some of the most demanding organizations in the world. Principal-led. Accountable to results.
      </p>
      
      <!-- Logo Grid with enhanced styling -->
      <div class="bg-paper rounded-3xl shadow-xl shadow-ink/5 p-6 md:p-12 max-w-5xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-8 md:gap-12 items-center justify-items-center">
          {[
            { src: "/images/logos/upperhand.svg", label: "Upper Hand" },
            { src: "/images/logos/perplexity.svg", label: "Perplexity" },
            { src: "/images/logos/samsung.svg", label: "Samsung" },
            { src: "/images/logos/tesla.svg", label: "Tesla" },
            { src: "/images/logos/rivian.svg", label: "Rivian" },
            { src: "/images/logos/conedison.svg", label: "Con Edison" },
            { src: "/images/logos/weavegrid.svg", label: "WeaveGrid" },
          ].map(({ src, label }) => (
            <div class="flex flex-col items-center gap-2 group transition-all duration-300 hover:scale-105">
              <img src={src} alt={label} class="h-6 md:h-10 w-auto opacity-60 group-hover:opacity-100 transition-opacity duration-300" />
              <span class="text-[10px] md:text-xs text-graphite uppercase tracking-widest">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- The Insight -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-paper py-16 md:py-24">
    <div class="max-w-screen-xl mx-auto px-5 md:px-8">
      <div class="max-w-4xl mx-auto">
        <h3 class="text-xs uppercase tracking-[0.2em] text-petrol mb-6 font-medium">The Insight</h3>
        <h2 class="font-sans text-3xl sm:text-4xl md:text-5xl font-bold text-ink mb-8">Why most AI projects fail — and how we fix it</h2>
        <p class="text-xl md:text-2xl text-graphite leading-relaxed mb-8 max-w-3xl">
          <strong class="text-ink">93% of AI projects stall.</strong> Not because the pilots fail — because there's no organizational foundation to build on. The real question: can your organization describe its own work in a form machines can act on?
        </p>
        <p class="text-lg text-graphite leading-relaxed max-w-3xl">
          Which rules are documented? Which ones live in someone's head? Which exceptions matter? Until you can answer that, AI tools are just faster ways to do the wrong thing. The journey from <a href="/capabilities" class="text-petrol underline underline-offset-2 hover:text-petrol/80 transition-colors">tribal to coherent</a> starts with making your work legible to machines. That's what we do — and why engagements that take others quarters take us weeks.
        </p>
      </div>
    </div>
  </div>

  <!-- The Journey -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-ink py-16 md:py-24">
    <div class="max-w-screen-xl mx-auto px-5 md:px-8">
      <div class="max-w-4xl mx-auto">
        <h3 class="text-xs uppercase tracking-[0.2em] text-petrol-light mb-6 font-medium">The Journey</h3>
        <h2 class="font-sans text-3xl sm:text-4xl md:text-5xl font-bold text-paper mb-6">From tribal to coherent</h2>
        <p class="text-lg text-paper/70 leading-relaxed mb-12 max-w-2xl">
          Every organization is somewhere on this path. The transitions — not the levels — are where all the value lives.
        </p>

        <!-- Level progression (compact) -->
        <div class="flex flex-wrap items-center gap-x-1 gap-y-2 mb-12">
          {(['Tribal', 'Experimenting', 'Legible', 'Knowledgeable', 'Adaptive', 'Self-Improving'] as const).map((name, i) => (
            <div class="flex items-center gap-1.5">
              <span class="text-xs font-mono text-petrol-light">L{i}</span>
              <span class="text-sm font-medium text-paper/80">{name}</span>
              {i < 5 && <span class="text-paper/20 mx-1">&rarr;</span>}
            </div>
          ))}
        </div>

        <!-- Three key transitions -->
        <div class="grid md:grid-cols-3 gap-6">
          <div class="border border-paper/10 rounded-2xl p-6">
            <p class="text-xs uppercase tracking-widest text-petrol-light mb-3 font-medium">L1 &rarr; L2</p>
            <h3 class="text-lg font-bold text-paper mb-3">Make your organization legible</h3>
            <p class="text-sm text-paper/60 leading-relaxed mb-4">
              Document the rules, exceptions, and tribal knowledge that only live in people's heads — in a form machines can follow.
            </p>
            <p class="text-sm text-petrol-light font-medium">Invoice processing: 15 min &rarr; 30 sec</p>
          </div>
          <div class="border border-paper/10 rounded-2xl p-6">
            <p class="text-xs uppercase tracking-widest text-petrol-light mb-3 font-medium">L2 &rarr; L3</p>
            <h3 class="text-lg font-bold text-paper mb-3">Connect your proprietary data</h3>
            <p class="text-sm text-paper/60 leading-relaxed mb-4">
              Generic AI uses generic data. The real shift happens when AI answers questions about <em class="text-paper/80">your</em> invoices, surveys, and documents — with sources.
            </p>
            <p class="text-sm text-petrol-light font-medium">Talent reports: half a day &rarr; 30 seconds</p>
          </div>
          <div class="border border-paper/10 rounded-2xl p-6">
            <p class="text-xs uppercase tracking-widest text-petrol-light mb-3 font-medium">L3 &rarr; L5</p>
            <h3 class="text-lg font-bold text-paper mb-3">Build systems that learn</h3>
            <p class="text-sm text-paper/60 leading-relaxed mb-4">
              The best AI systems don't just execute — they improve. Every interaction teaches the system something new. Competitive advantage compounds.
            </p>
            <p class="text-sm text-petrol-light font-medium">500M tweets/day &rarr; 5-minute briefings</p>
          </div>
        </div>

        <div class="mt-10 text-center">
          <a
            href="/capabilities"
            class="inline-block px-8 py-4 border-2 border-paper/20 text-paper font-medium uppercase text-sm tracking-wider rounded-full hover:border-petrol hover:text-petrol hover:-translate-y-0.5 transition-all duration-200"
          >
            Explore the Full Framework
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- How We Do It -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-tint-warm py-16 md:py-24">
    <div class="max-w-screen-xl mx-auto px-5 md:px-8">
      <div class="max-w-4xl mx-auto">
        <h3 class="text-xs uppercase tracking-[0.2em] text-petrol mb-6 font-medium">Our Approach</h3>
        <h2 class="font-sans text-3xl sm:text-4xl md:text-5xl font-bold text-ink mb-8 md:mb-10">How we deliver</h2>

        <div class="prose prose-lg max-w-none text-graphite">
        <p class="text-lg md:text-xl leading-relaxed mb-8">
          Every engagement begins with a question most consultants skip: <em>can your organization describe its own work?</em> Before we build anything, we develop a thorough understanding of how your processes actually run — not how the org chart says they should.
        </p>

        <div class="bg-paper rounded-3xl p-8 md:p-10 my-10 md:my-12 shadow-lg shadow-ink/5 relative overflow-hidden">
          <span class="absolute top-4 left-6 text-7xl md:text-8xl text-petrol/10 font-serif leading-none">"</span>
          <p class="text-lg md:text-xl italic text-graphite mb-6 relative z-10 pl-4 md:pl-8">
            TheFocus.AI didn't just build what we asked for—they helped us understand what we <strong class="text-ink not-italic">actually needed</strong>. The strategic clarity they brought was as valuable as the technical delivery.
          </p>
          <p class="text-sm font-medium text-ink relative z-10 pl-4 md:pl-8">
            — <a href="https://www.linkedin.com/in/joshclee/"
            class="text-petrol hover:underline">Josh Lee</a>, CEO,
            AI-Solutions
          </p>
        </div>

        <h3 class="font-sans text-xl md:text-2xl font-bold text-ink mb-6">What to expect:</h3>
        <ul class="space-y-5 mb-8">
          <li class="flex gap-4">
            <span class="text-petrol font-bold flex-shrink-0">→</span>
            <span class="text-base md:text-lg"><strong>Discover</strong> — We audit your systems, data, and workflows. More importantly, we find the tribal knowledge — the undocumented rules, exceptions, and judgment calls that your team carries in their heads.</span>
          </li>
          <li class="flex gap-4">
            <span class="text-petrol font-bold flex-shrink-0">→</span>
            <span class="text-base md:text-lg"><strong>Structure</strong> — We turn that knowledge into a form machines can act on: schemas, validation rules, canonical data models. This is the organizational legibility work.</span>
          </li>
          <li class="flex gap-4">
            <span class="text-petrol font-bold flex-shrink-0">→</span>
            <span class="text-base md:text-lg"><strong>Build</strong> — We deliver production AI systems with traceability built in. Every answer can be traced back to its source. Your team trusts the output because they can verify it.</span>
          </li>
        </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Engagement Models -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto">
        <h3 class="text-xs uppercase tracking-[0.2em] text-petrol mb-6 font-medium">How We Engage</h3>
        <h2 class="font-sans text-3xl sm:text-4xl md:text-5xl font-bold text-ink mb-10">Three ways to work together</h2>

      <div class="space-y-6 md:space-y-8">
        <!-- Strategy -->
        <a href="mailto:hey@thefocus.ai?subject=Assessment%20%26%20Roadmap" class="flex gap-5 md:gap-6 items-start p-5 md:p-6 rounded-2xl border border-transparent hover:border-petrol/20 hover:bg-tint-cool/30 transition-all group">
          <div class="bg-tint-cool rounded-xl md:rounded-2xl p-3 md:p-4 flex-shrink-0 w-14 h-14 md:w-24 md:h-24 flex items-center justify-center">
            <img src="/images/illustrations/guide.svg" alt="" class="w-8 h-8 md:w-14 md:h-14" />
          </div>
          <div class="pt-1 flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="font-sans text-lg md:text-xl font-bold text-ink">Assessment & Roadmap</h3>
              <span class="text-xs font-medium text-petrol bg-petrol/10 px-2 py-1 rounded-full">4-6 weeks</span>
            </div>
            <p class="text-graphite text-base leading-relaxed mb-2">
              A 4-6 week deep-dive into your organization. We map your AI maturity, find the highest-leverage opportunities, and deliver a prioritized roadmap. Clarity — not a slide deck to ignore.
            </p>
            <span class="text-petrol font-medium text-sm group-hover:underline">Discuss your starting point →</span>
          </div>
        </a>

        <!-- Build -->
        <a href="mailto:hey@thefocus.ai?subject=Build%20%26%20Ship" class="flex gap-5 md:gap-6 items-start p-5 md:p-6 rounded-2xl border border-transparent hover:border-petrol/20 hover:bg-tint-warm/30 transition-all group">
          <div class="bg-tint-warm rounded-xl md:rounded-2xl p-3 md:p-4 flex-shrink-0 w-14 h-14 md:w-24 md:h-24 flex items-center justify-center">
            <img src="/images/illustrations/build.svg" alt="" class="w-8 h-8 md:w-14 md:h-14" />
          </div>
          <div class="pt-1 flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="font-sans text-lg md:text-xl font-bold text-ink">Build & Ship</h3>
              <span class="text-xs font-medium text-petrol bg-petrol/10 px-2 py-1 rounded-full">6-12 weeks</span>
            </div>
            <p class="text-graphite text-base leading-relaxed mb-2">
              For teams ready to ship. We build production AI systems in 6-12 weeks — integrated into your infrastructure, built to last. Your team owns it when we're done.
            </p>
            <span class="text-petrol font-medium text-sm group-hover:underline">Scope your project →</span>
          </div>
        </a>

        <!-- Partnership -->
        <a href="mailto:hey@thefocus.ai?subject=Partnership%20Inquiry" class="flex gap-5 md:gap-6 items-start p-5 md:p-6 rounded-2xl border border-transparent hover:border-petrol/20 hover:bg-tint-lavender/30 transition-all group">
          <div class="bg-tint-lavender rounded-xl md:rounded-2xl p-3 md:p-4 flex-shrink-0 w-14 h-14 md:w-24 md:h-24 flex items-center justify-center">
            <img src="/images/illustrations/modernize.svg" alt="" class="w-8 h-8 md:w-14 md:h-14" />
          </div>
          <div class="pt-1 flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="font-sans text-lg md:text-xl font-bold text-ink">Ongoing Partnership</h3>
              <span class="text-xs font-medium text-petrol bg-petrol/10 px-2 py-1 rounded-full">Retained</span>
            </div>
            <p class="text-graphite text-base leading-relaxed mb-2">
              Ongoing AI expertise embedded in your team. We keep building, optimizing, and expanding capabilities as your needs evolve. Your competitive advantage compounds.
            </p>
            <span class="text-petrol font-medium text-sm group-hover:underline">Explore partnership →</span>
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
