---
import BaseLayout from "../layout/BaseLayout.astro";
import BreadcrumbList from "../components/schemas/breadcrumb.astro";

const mailto = "mailto:hey@thefocus.ai?subject=AI%20Maturity%20Assessment";

const maturityLevels = [
  {
    level: 0,
    code: "L0",
    name: "Tribal",
    tagline: "Knowledge lives in people's heads",
    description: "Everything is manual. Processes depend on who knows what. A key person leaves and critical workflows break.",
    commonMistake: "We need to pick the right AI tool.",
    reality: "This level resolves itself — people start using ChatGPT on their own. The real question is what happens next.",
    bridge: null as null | { service: string; description: string; proof: { text: string; href: string }[] }
  },
  {
    level: 1,
    code: "L1",
    name: "Experimenting",
    tagline: "Individual tools, nothing shared",
    description: "Employees are using ChatGPT or Copilot on their own. Some get real value — but nothing is shared, nothing compounds. When someone leaves, their workflows leave with them.",
    commonMistake: '"We need an AI strategy" or "We need better models."',
    reality: "The blocker isn't technology — it's that you can't describe your own workflows. AI can't act on knowledge that only lives in people's heads.",
    note: "This is where Pilot Purgatory lives. 93% of AI projects stall here — not because the pilots fail, but because there's no organizational foundation to build on.",
    bridge: {
      service: "Process Audit & Formalization",
      description: "We document your actual workflows — the rules, exceptions, and tribal knowledge — in a form machines can follow.",
      proof: [
        { text: "Vibe Check — fix your AI-coded app", href: "/vibe-check" },
        { text: "QB Sync — tribal cost codes discovered & formalized", href: "/case-study/qbsync" }
      ]
    }
  },
  {
    level: 2,
    code: "L2",
    name: "Legible",
    tagline: "Your organization can describe its own work",
    description: "AI tools are connected to real systems — CRM, codebase, analytics, accounting. There's structure and consistency. But your proprietary data is still locked in folders nobody can search.",
    commonMistake: '"We\'ve integrated the tools, we\'re done."',
    reality: "Integration is the beginning, not the end. Your invoices, surveys, research docs — the data that makes your business unique — is still invisible to AI.",
    bridge: {
      service: "Knowledge Layer",
      description: "Turn your proprietary documents into a searchable, queryable knowledge base with source attribution.",
      proof: [
        { text: "Fountain Creek — invoice parsing, 94.5% validated accuracy", href: "/case-study/fountain-creek" },
        { text: "TezLab — conversational AI over proprietary EV data", href: "/case-study/tezlab-ai" },
        { text: "Onboarding — benefits documents extracted against unified schema", href: "/case-study/onboarding" }
      ]
    }
  },
  {
    level: 3,
    code: "L3",
    name: "Knowledgeable",
    tagline: "Your organization knows what it knows",
    description: "Teams ask ad hoc questions and get instant answers — the 45-minutes-to-5-seconds transformation. New employees query institutional knowledge from day one. But adoption stalls without traceability.",
    commonMistake: '"We need more data" or "We need RAG."',
    reality: "The blocker is trust. Your team won't act on what the system says until they can verify it. Every answer needs to trace back to the specific document it came from.",
    bridge: {
      service: "Insight Engine",
      description: "Move from answering questions to proactively surfacing what matters — and put decision-making power closest to the problem.",
      proof: [
        { text: "Distill — 500M tweets/day filtered into 5-minute briefings", href: "/case-study/distill" },
        { text: "Upper Hand — executives self-serve insights that required analyst teams", href: "/case-study/upperhand-ai" }
      ]
    }
  },
  {
    level: 4,
    code: "L4",
    name: "Adaptive",
    tagline: "The system brings insights to you",
    description: "AI proactively surfaces insights. The organization changes shape — people closest to the problem drive decisions that used to require engineering. Power moves to whoever asks the best question.",
    commonMistake: '"We need more engineers" or "We need to scale what we built."',
    reality: "The blocker is organizational. When the system surfaces insights, the people closest to the problem need decision-making authority. Your org chart may not match your information flow.",
    bridge: {
      service: "Feedback Loop Design",
      description: "Close the loop — capture how humans correct the system so everyday use makes it smarter over time.",
      proof: [
        { text: "AI Back Office — every command teaches the system; meetings become project context", href: "/case-study/ai-back-office" }
      ]
    }
  },
  {
    level: 5,
    code: "L5",
    name: "Self-Improving",
    tagline: "The system learns from every interaction",
    description: "Tribal knowledge crystallizes into documented workflows. Feedback loops are continuous. The system learns and improves on its own. Competitive advantage compounds.",
    commonMistake: '"We need autonomous agents."',
    reality: "The blocker is that you haven't built the feedback loop. The work is capturing expert correction in a form the system can learn from.",
    bridge: null
  }
];

const assessmentClusters = [
  {
    label: "Tribal → Legible",
    levels: "L0 — L1",
    signals: [
      "Your team uses ChatGPT individually but there's no organizational strategy",
      "AI feels interesting but you don't know where to begin",
      "The real question isn't which tool to pick — it's whether you can describe your own workflows"
    ],
    engagement: "Assessment & Roadmap",
    timeline: "4-6 weeks",
    deliverables: ["AI opportunity assessment", "Process documentation", "Prioritized roadmap", "Build vs. buy analysis"],
    cta: "Let's map your starting point",
    mailto: "mailto:hey@thefocus.ai?subject=Assessment%20%26%20Roadmap"
  },
  {
    label: "Legible → Knowledgeable",
    levels: "L2 — L3",
    signals: [
      "You have AI tools connected to your workflows but they feel generic",
      "Your proprietary data — the documents, surveys, records that make your business unique — is still locked in folders nobody can search",
      "You know it could unlock more, but aren't sure how"
    ],
    engagement: "Build & Ship",
    timeline: "6-12 weeks",
    deliverables: ["Document ingestion pipeline", "Semantic knowledge base", "Conversational query interface", "Source-attributed answers"],
    cta: "Let's unlock your data",
    mailto: "mailto:hey@thefocus.ai?subject=Build%20%26%20Ship"
  },
  {
    label: "Knowledgeable → Self-Improving",
    levels: "L4 — L5",
    signals: [
      "AI is driving real business outcomes, but you want it to compound",
      "You need systems that learn from themselves, roles that evolve with the technology, and governance that adapts",
      "The question is no longer 'does AI work?' — it's 'how does our organization change?'"
    ],
    engagement: "Ongoing Partnership",
    timeline: "Monthly retainer",
    deliverables: ["Dedicated team access", "Feedback loop design", "Continuous optimization", "Capability expansion", "Team training"],
    cta: "Let's build the next level",
    mailto: "mailto:hey@thefocus.ai?subject=AI%20Assessment%20-%20Scaling"
  }
];

---

<BaseLayout
  pageTitle="AI Maturity Framework & Consulting Services | TheFocus.AI"
  description="Where is your organization on the AI journey? TheFocus.AI's proven maturity framework (L0–L5) takes growth-stage companies from tribal knowledge to self-improving AI systems. Production AI in weeks, not quarters."
  category="capabilities"
>
  <BreadcrumbList slot="head" />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "TheFocus.AI Engagement Models",
    "description": "AI consulting engagement models for growth-stage companies",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Service",
          "name": "Assessment & Roadmap",
          "description": "4-6 week engagement to assess your organization's AI maturity and build a prioritized roadmap. Deliverables: AI opportunity assessment, process documentation, build vs. buy analysis.",
          "provider": { "@type": "Organization", "name": "TheFocus.AI", "url": "https://thefocus.ai" },
          "serviceType": "AI Strategy Consulting"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Service",
          "name": "Build & Ship",
          "description": "6-12 week engagement to build and deploy production AI systems. Deliverables: document ingestion pipeline, semantic knowledge base, conversational query interface, source-attributed answers.",
          "provider": { "@type": "Organization", "name": "TheFocus.AI", "url": "https://thefocus.ai" },
          "serviceType": "AI Development"
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Service",
          "name": "Ongoing Partnership",
          "description": "Monthly retainer for organizations with production AI who want it to compound. Includes dedicated team, feedback loop design, continuous optimization, and team training.",
          "provider": { "@type": "Organization", "name": "TheFocus.AI", "url": "https://thefocus.ai" },
          "serviceType": "AI Partnership"
        }
      }
    ]
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do we need clean data first?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. In fact, discovering that your data isn't clean is part of the value. Most organizations don't realize how much tribal knowledge — naming conventions, exception rules, approval workflows — lives only in people's heads until they try to connect AI to it. We help you through that process."
        }
      },
      {
        "@type": "Question",
        "name": "What if we don't know exactly what we need?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "That's normal — and it's what Assessment engagements are for. Most companies overestimate where they are on the maturity framework. The honest starting point is usually: 'Can we describe our own workflows in a form a machine can follow?' If the answer is 'not yet,' that's where we begin."
        }
      },
      {
        "@type": "Question",
        "name": "How is this different from other AI consultancies?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We build. Most AI consultancies deliver decks and recommendations. We deliver production systems — working in weeks, not quarters. And we're honest about organizational readiness: if your processes aren't formalized enough for AI, we'll tell you that and help you fix it, rather than building on a shaky foundation."
        }
      }
    ]
  })} />
  <!-- Hero -->
  <div class="max-w-4xl mx-auto">
    <section class="py-8 md:py-16">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-6 font-medium">Building an Intelligent Organization</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold mb-6 text-ink leading-tight">
        Where is your organization<br/>on the AI journey?
      </h1>
      <p class="text-xl md:text-2xl text-graphite leading-relaxed mb-4 max-w-3xl">
        Most AI projects fail not because the technology doesn't work — but because the organization can't describe its own work in a form machines can act on.
      </p>
      <p class="text-lg text-graphite leading-relaxed mb-10 max-w-3xl">
        The journey is from <strong class="text-ink">tribal to coherent</strong> — and each transition has a different blocker. Different departments sit at different points. Find yours below.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#assessment"
          class="inline-block px-8 py-4 bg-petrol text-paper font-medium uppercase text-sm tracking-wider rounded-full hover:bg-petrol/90 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 text-center"
        >
          Find Out Where You Are
        </a>
        <a
          href="#framework"
          class="inline-block px-8 py-4 border-2 border-ink/20 text-ink font-medium uppercase text-sm tracking-wider rounded-full hover:border-petrol hover:text-petrol hover:-translate-y-0.5 transition-all duration-200 text-center"
        >
          See the Framework
        </a>
      </div>
    </section>
  </div>

  <!-- Visual Progression — Staircase -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-ink">
    <div class="max-w-screen-xl mx-auto px-5 md:px-8 py-16 md:py-20">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-4 font-medium text-center">The Framework</p>
      <h2 class="text-3xl md:text-4xl font-bold text-paper mb-12 text-center">Six levels of AI maturity</h2>

      <!-- Staircase: ascending cards -->
      <div class="hidden lg:grid grid-cols-6 gap-3 items-end max-w-5xl mx-auto">
        {maturityLevels.map((level, i) => (
          <a
            href={`#level-${level.level}`}
            class="block border border-paper/10 rounded-xl p-4 hover:bg-paper/10 transition-all"
            style={`min-height: ${100 + i * 28}px; background: rgba(255,255,255,${0.03 + i * 0.02});`}
          >
            <span class="text-xs font-mono font-bold text-paper/90">{level.code}</span>
            <h3 class="text-base font-bold text-paper mt-1 leading-tight">{level.name}</h3>
            <p class="text-xs text-paper/50 mt-2 leading-snug">{level.tagline}</p>
          </a>
        ))}
      </div>

      <!-- Mobile: vertical list -->
      <div class="lg:hidden grid grid-cols-2 sm:grid-cols-3 gap-3 max-w-2xl mx-auto">
        {maturityLevels.map((level, i) => (
          <a
            href={`#level-${level.level}`}
            class="block border border-paper/10 rounded-xl p-4 hover:bg-paper/10 transition-all"
            style={`background: rgba(255,255,255,${0.03 + i * 0.02});`}
          >
            <span class="text-xs font-mono font-bold text-paper/90">{level.code}</span>
            <h3 class="text-base font-bold text-paper mt-1 leading-tight">{level.name}</h3>
            <p class="text-xs text-paper/50 mt-2 leading-snug">{level.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Self-Assessment + Engagement Types (MOVED UP) -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-tint-warm" id="assessment">
    <div class="max-w-screen-xl mx-auto px-5 md:px-8 py-16 md:py-20">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-4 font-medium">Where Are You?</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4">Find your starting point</h2>
      <p class="text-lg text-graphite mb-12 max-w-2xl">
        Pick the cluster that sounds most like you. Each one maps to a specific engagement.
      </p>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl">
        {assessmentClusters.map((cluster) => (
          <div class="bg-paper rounded-2xl p-6 md:p-8 shadow-sm flex flex-col">
            <div class="mb-4">
              <span class="text-xs font-mono text-petrol bg-petrol/10 px-2 py-1 rounded">{cluster.levels}</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-4">{cluster.label}</h3>
            <ul class="space-y-3 mb-6">
              {cluster.signals.map((signal) => (
                <li class="flex items-start gap-2">
                  <span class="text-petrol mt-0.5 flex-shrink-0">&#x2713;</span>
                  <span class="text-sm text-graphite">{signal}</span>
                </li>
              ))}
            </ul>

            <div class="pt-4 border-t border-ink/10 mb-6 flex-1">
              <div class="flex items-center gap-3 mb-2">
                <h4 class="text-base font-bold text-ink">{cluster.engagement}</h4>
                <span class="text-xs font-medium text-petrol bg-petrol/10 px-2 py-0.5 rounded-full">{cluster.timeline}</span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {cluster.deliverables.map((d) => (
                  <span class="text-xs text-graphite bg-ink/5 px-2.5 py-1 rounded-full">{d}</span>
                ))}
              </div>
            </div>

            <a
              href={cluster.mailto}
              class="inline-block px-6 py-3 bg-petrol text-paper font-medium uppercase text-xs tracking-wider rounded-full hover:bg-petrol/90 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 text-center"
            >
              {cluster.cta} &rarr;
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Detailed Level Cards (compressed) -->
  <div class="max-w-4xl mx-auto" id="framework">
    <section class="py-16 md:py-20">
      <h2 class="text-xs uppercase tracking-[0.2em] text-petrol mb-8 font-medium">Level by Level</h2>

      <div class="space-y-6">
        {maturityLevels.map((level) => (
          <div
            id={`level-${level.level}`}
            class="border border-ink/10 rounded-2xl p-6 md:p-8 hover:border-petrol/30 transition-all scroll-mt-24"
          >
            <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-8">
              <div class="flex-shrink-0">
                <span class="text-2xl md:text-3xl font-mono font-bold text-petrol/30">{level.code}</span>
              </div>
              <div class="flex-1">
                <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4 mb-3">
                  <h3 class="text-2xl font-bold text-ink">{level.name}</h3>
                  <span class="text-sm font-medium text-petrol bg-petrol/10 px-3 py-1 rounded-full w-fit">{level.tagline}</span>
                </div>
                <p class="text-graphite leading-relaxed mb-4">{level.description}</p>

                {level.commonMistake && (
                  <div class="mb-4 bg-tint-warm/40 rounded-xl p-4">
                    <p class="text-sm text-graphite mb-1">
                      <span class="font-medium text-ink">The common mistake:</span>{' '}
                      <em>{level.commonMistake}</em>
                    </p>
                    <p class="text-sm text-graphite">
                      <span class="font-medium text-ink">The reality:</span>{' '}
                      <em>{level.reality}</em>
                    </p>
                  </div>
                )}

                {'note' in level && level.note && (
                  <p class="text-sm text-vermilion/80 italic mb-4">{level.note}</p>
                )}

                {level.bridge && (
                  <div class="pt-4 border-t border-ink/5">
                    <p class="text-xs uppercase tracking-widest text-petrol mb-1 font-medium">
                      Next level &rarr; {level.bridge.service}
                    </p>
                    <p class="text-sm text-graphite mb-3">{level.bridge.description}</p>
                    <div class="flex flex-col gap-2">
                      {level.bridge.proof.map((item) => (
                        <a href={item.href} class="flex items-center gap-3 text-sm group">
                          <span class="text-petrol flex-shrink-0">&rarr;</span>
                          <span class="text-ink group-hover:text-petrol transition-colors font-medium">
                            {item.text}
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- How We Work + Is This For You -->
  <div class="max-w-4xl mx-auto">
    <section class="mb-20">
      <div class="bg-ink text-paper rounded-3xl p-8 md:p-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-8">How we work with you</h2>

        <div class="grid md:grid-cols-3 gap-8 md:gap-10">
          <div>
            <h3 class="text-lg font-bold text-petrol mb-4">What we do</h3>
            <ul class="space-y-3">
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">Walk through the framework with your team</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">You self-identify where each department sits</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">We build a roadmap from where you are to where you want to be</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">Every level up is a clear, scoped engagement</span>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="text-lg font-bold text-petrol mb-4">What you get</h3>
            <ul class="space-y-3">
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">Honest assessment — no upselling to where you don't need to be</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">Practical roadmap with concrete next steps</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">Quick wins at your current level while building toward the next</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">A partner who meets you where you are</span>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="text-lg font-bold text-petrol mb-4">This is for you if</h3>
            <ul class="space-y-3">
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">You're a founder, CEO, or product leader at a growth-stage company</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">You have a product that works — now you want to make it smarter with AI</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">You don't have an internal AI/ML team (or yours is stretched thin)</span>
              </li>
              <li class="flex gap-3">
                <span class="text-petrol flex-shrink-0">&#x2713;</span>
                <span class="text-paper/80">You need working AI in weeks, not a 6-month "discovery phase"</span>
              </li>
            </ul>
          </div>
        </div>

        <p class="text-paper/60 mt-8 text-sm">
          The key insight from every engagement: the technology isn't usually the blocker. The organizational knowledge is. Companies discover how much of their work was never formalized — and formalizing it is the most valuable part of the project.
        </p>
      </div>
    </section>
  </div>

  <!-- FAQ -->
  <div class="max-w-4xl mx-auto">
    <section class="mb-16">
      <h2 class="text-xs uppercase tracking-[0.2em] text-petrol mb-8 font-medium">Common Questions</h2>

      <div class="space-y-6">
        <div class="border-t border-ink/10 pt-6">
          <h3 class="text-lg font-bold text-ink mb-2">Do we need clean data first?</h3>
          <p class="text-graphite">No. In fact, discovering that your data <em>isn't</em> clean is part of the value. Most organizations don't realize how much tribal knowledge — naming conventions, exception rules, approval workflows — lives only in people's heads until they try to connect AI to it. We help you through that process.</p>
        </div>
        <div class="border-t border-ink/10 pt-6">
          <h3 class="text-lg font-bold text-ink mb-2">What if we don't know exactly what we need?</h3>
          <p class="text-graphite">That's normal — and it's what Assessment engagements are for. Most companies overestimate where they are on the maturity framework. The honest starting point is usually: "Can we describe our own workflows in a form a machine can follow?" If the answer is "not yet," that's where we begin.</p>
        </div>
        <div class="border-t border-ink/10 pt-6">
          <h3 class="text-lg font-bold text-ink mb-2">How is this different from other AI consultancies?</h3>
          <p class="text-graphite">We build. Most AI consultancies deliver decks and recommendations. We deliver production systems — working in weeks, not quarters. And we're honest about organizational readiness: if your processes aren't formalized enough for AI, we'll tell you that and help you fix it, rather than building on a shaky foundation.</p>
        </div>
      </div>
    </section>
  </div>

  <!-- Final CTA -->
  <div class="max-w-4xl mx-auto">
    <div class="border-t border-ink/10 pt-16 pb-8">
      <h2 class="text-3xl md:text-4xl font-bold mb-6 text-ink">Ready to find your starting point?</h2>
      <p class="text-xl text-graphite mb-8">
        We work directly with founders and product leaders. The conversation starts with understanding where you are — not selling you where we think you should be.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
