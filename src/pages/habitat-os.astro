---
import BaseLayout from "../layout/BaseLayout.astro";

const mailto = "mailto:hey@thefocus.ai?subject=Habitat%20OS%20%E2%80%94%20Enterprise%20Inquiry";
const workstreamsMailto = "mailto:hey@thefocus.ai?subject=Habitat%20WorkStreams%20%E2%80%94%20Enterprise%20Inquiry";

const workstreamPrinciples = [
  {
    eyebrow: "Private by default",
    title: "Their stream, their control.",
    body: "Every employee gets a WorkStream. Their prompts, their artifacts, their workflows. Nothing is shared, seen, or indexed until they choose to promote it.",
  },
  {
    eyebrow: "Promotable when ready",
    title: "One click lifts an artifact to the team.",
    body: "When a prompt actually works or a workflow is worth keeping, promote it to the team. Promote again to the org. The employee stays in control; the organization stops losing good work to closed tabs.",
  },
  {
    eyebrow: "Discoverable when promoted",
    title: "Skeptics can watch. Builders get credit.",
    body: "Teammates can read, fork, and build on promoted artifacts. Power users compound. Skeptics participate at their own pace. No forced migration, no champion burnout.",
  },
];

type WorkstreamArtifact = {
  kind: "spreadsheet" | "pdf" | "deck";
  filename: string;
};

type WorkstreamCard = {
  habitat: string;
  initials: string;
  author: string;
  role: string;
  prompt: string;
  response: string;
  artifact: WorkstreamArtifact;
  meta: string;
  badge: "private" | "team" | "org";
};

const workstreamFeed: WorkstreamCard[] = [
  {
    habitat: "Monthly Close Habitat",
    initials: "MR",
    author: "Maya R.",
    role: "Controller",
    prompt: "Draft the variance commentary for Q3 close. Flag anything over 8% vs. forecast.",
    response: "Ran the close checklist against GL. Three variances over threshold: SaaS expense +12%, headcount +9%, vendor rebates −15%. Draft commentary attached with sources.",
    artifact: { kind: "spreadsheet", filename: "q3-variance-commentary.xlsx" },
    meta: "Shared to Finance · 2h ago · 4 teammates viewed",
    badge: "team",
  },
  {
    habitat: "Hiring Pipeline Habitat",
    initials: "JP",
    author: "James P.",
    role: "Head of Talent",
    prompt: "Screen this week's inbound for the Staff Eng role using our rubric.",
    response: "6 candidates matched L4+ criteria. 2 flagged for manager review. Promoted rubric v3 from Diana's stream — kept her weighting on systems design.",
    artifact: { kind: "pdf", filename: "staff-eng-screening-summary.pdf" },
    meta: "Private · Promote to team?",
    badge: "private",
  },
  {
    habitat: "Executive Reporting Habitat",
    initials: "DC",
    author: "Diana C.",
    role: "CFO",
    prompt: "Build the board slide on burn vs. plan using the Nov dataset.",
    response: "Pulled from the warehouse. Burn is $1.2M under plan, runway extended by 3.5 months. Draft slide matches your executive voice template.",
    artifact: { kind: "deck", filename: "board-nov-burn-vs-plan.pptx" },
    meta: "Promoted to Leadership · originated in Diana's stream",
    badge: "org",
  },
];

const popularPrompts = [
  { title: "Variance commentary over 8%", habitat: "Monthly Close", runs: 12 },
  { title: "Candidate rubric v3", habitat: "Hiring Pipeline", runs: 9 },
  { title: "Board burn slide", habitat: "Executive Reporting", runs: 6 },
  { title: "Invoice exception triage", habitat: "Invoice Processing", runs: 5 },
  { title: "Onboarding runbook v2", habitat: "Customer Onboarding", runs: 3 },
];

const pillars = [
  {
    eyebrow: "Deployed where you say",
    title: "Your cloud, your keys, your rules.",
    body: "Habitat OS runs in your VPC, your dedicated cloud account, or our managed single-tenant environment. Customer-owned data stays customer-side. Model provider keys are yours to bring. On-prem is available case-by-case for regulated deployments.",
  },
  {
    eyebrow: "Open at the core",
    title: "Auditable engine, accountable distribution.",
    body: "The Habitat primitives — persona, tools, memory, sub-agents, evals — live in our open-source engine, Umwelten. Your security team can read every line. The enterprise distribution adds identity, observability, integrations, and human support.",
  },
  {
    eyebrow: "Principal-led accountability",
    title: "The people who built it run it.",
    body: "Every engagement is led by a named principal. No rotating analysts, no offshore handoffs, no layers between the people who understand your Habitat and the people fixing it when something breaks. Your CISO gets a direct line.",
  },
  {
    eyebrow: "One platform, every Habitat",
    title: "Build one, the next one is easier.",
    body: "Your monthly close Habitat, your hiring Habitat, your executive reporting Habitat — all run on the same runtime, share the same identity layer, and benefit from the same operational tooling. Scale across departments without re-architecting each time.",
  },
];

type HabitatEntry = {
  title: string;
  blurb: string;
  href?: string;
  levels?: string;
};

const habitatLibrary: HabitatEntry[] = [
  {
    title: "Monthly Close",
    blurb: "Formalize the close checklist, reconciliation rules, and approval logic into a Habitat that runs every month.",
    href: "/offerings/monthly-close",
    levels: "L1 → L2",
  },
  {
    title: "Invoice Processing",
    blurb: "Any vendor format in, structured data out. The Habitat learns your exception patterns as it goes.",
    href: "/offerings/invoice-processing",
    levels: "L1 → L2",
  },
  {
    title: "Hiring Pipeline",
    blurb: "Candidate screening, scheduling, and pipeline hygiene. Stops losing candidates to your own process.",
    href: "/offerings/hiring-pipeline",
    levels: "L1 → L2",
  },
  {
    title: "Customer Onboarding",
    blurb: "New client setup that doesn't depend on who remembers what. The Habitat carries the institutional memory.",
    href: "/offerings/customer-onboarding",
    levels: "L1 → L2",
  },
  {
    title: "Executive Reporting",
    blurb: "Real-time answers against your data, not reformatted dashboards. Your executives stop waiting for slides.",
    href: "/offerings/executive-reporting",
    levels: "L2 → L3",
  },
  {
    title: "QuickBooks Sync",
    blurb: "Project accounting from QuickBooks to your reporting tools, with tribal cost codes formalized into machine-readable rules.",
  },
  {
    title: "HR Lifecycle",
    blurb: "Onboarding, performance cycles, compensation changes. The workflows currently living in one person's head, formalized.",
  },
  {
    title: "Deck Prep",
    blurb: "Raw data into board-ready narratives. Your executive voice, applied consistently across every deck.",
  },
  {
    title: "Executive Planning",
    blurb: "OKR tracking, cross-department alignment, exec briefings that write themselves — grounded in the data your team actually uses.",
  },
];

const integrations = [
  { name: "Snowflake", blurb: "Query your warehouse. Write back reconciled data." },
  { name: "Databricks", blurb: "Lakehouse access with governed schemas." },
  { name: "Microsoft 365", blurb: "Teams, Outlook, SharePoint, Excel." },
  { name: "Google Workspace", blurb: "Gmail, Drive, Sheets, Calendar." },
  { name: "Salesforce", blurb: "CRM read/write with field-level auth." },
  { name: "NetSuite", blurb: "Financial systems with role-scoped access." },
  { name: "Workday", blurb: "HR and workforce data integration." },
  { name: "QuickBooks", blurb: "Accounting for project-based businesses." },
  { name: "HRIS + ATS", blurb: "Greenhouse, Lever, Rippling, Gusto." },
  { name: "Slack", blurb: "Conversational surface for any Habitat." },
];

const lifecyclePhases = [
  {
    step: "1",
    name: "Discovery",
    duration: "1-2 weeks",
    body: "We map your actual workflow — not the documented version. Every workaround, exception, and judgment call. You receive an honest roadmap with clear build-vs-buy recommendations.",
    link: "Assessment & Roadmap engagement",
    href: "/capabilities#assessment",
  },
  {
    step: "2",
    name: "Build & Ship",
    duration: "2-6 weeks",
    body: "We formalize your tribal knowledge and deliver your first Habitat running on Habitat OS. Principal-led build, deployed to your environment, with documentation your team can own.",
    link: "Build & Ship engagement",
    href: "/capabilities#assessment",
  },
  {
    step: "3",
    name: "Habitat OS Runtime",
    duration: "Ongoing",
    body: "Your Habitat runs in production. We operate the runtime, maintain integrations, monitor behavior, and close feedback loops. New Habitats extend the same platform.",
    link: "Ongoing Partnership engagement",
    href: "/capabilities#assessment",
  },
];

const trustItems = [
  {
    title: "Deployment flexibility",
    status: "Available today",
    body: "Customer VPC, dedicated cloud account, or managed single-tenant on Vercel's enterprise AI Cloud. On-prem deployments supported case-by-case. Your infrastructure team chooses the boundary.",
  },
  {
    title: "Platform-level certifications",
    status: "Inherited from Vercel",
    body: "Our managed runtime runs on Vercel's enterprise platform — SOC 2 Type 2, ISO 27001:2022, PCI DSS Level 1, HIPAA-ready (BAA available), and GDPR with DPA. You inherit those controls at the infrastructure layer on day one.",
  },
  {
    title: "Network isolation",
    status: "Vercel Secure Compute",
    body: "Managed deployments use dedicated VPC isolation with static egress IPs, private connectivity to your backend systems, and NAT-gateway-controlled outbound traffic. Your allowlists stay short and stable.",
  },
  {
    title: "Edge protection",
    status: "Vercel Firewall",
    body: "DDoS mitigation, managed WAF, rate limiting, Attack Challenge Mode, and IP allow/deny rules sit in front of every Habitat endpoint. Configuration changes are logged and instantly reversible.",
  },
  {
    title: "Data boundary",
    status: "Always customer-controlled",
    body: "Customer data never leaves customer-controlled storage. Model provider keys can be customer-provided or brokered. Memory, audit logs, and session data persist in storage you own.",
  },
  {
    title: "Identity & access",
    status: "Enterprise SSO available",
    body: "SAML / OIDC integration with Okta, Microsoft Entra, and Google Workspace. Role-based access control scoped to Habitat and integration level. Every action is audit-logged with request-level traceability.",
  },
  {
    title: "Open-source auditability",
    status: "Public, on GitHub",
    body: "The Habitat engine is Umwelten — published under an OSI-compatible license at github.com/The-Focus-AI/umwelten. Your security team can read every line before deployment.",
  },
  {
    title: "Principal accountability",
    status: "Always",
    body: "Every engagement is led by a named principal. Your escalation path goes to the person who built your Habitat, not a support tier.",
  },
  {
    title: "TheFocus.AI program compliance",
    status: "SOC 2 Type I in progress",
    body: "Our own SOC 2 Type I audit is underway for 2026. HIPAA BAAs, ISO 27001, and sector-specific programs are evaluated case-by-case. Security posture documentation, deployment diagrams, and data-handling practices available on request under NDA.",
  },
];

const vercelGuarantees = [
  { label: "SOC 2 Type 2", detail: "Security · Confidentiality · Availability" },
  { label: "ISO 27001:2022", detail: "Information security management" },
  { label: "PCI DSS Level 1", detail: "Payment-grade controls at the edge" },
  { label: "HIPAA-ready", detail: "BAA available on Enterprise" },
  { label: "GDPR + DPA", detail: "EU data-handling commitments" },
  { label: "Secure Compute", detail: "Dedicated VPC + static egress IPs" },
];

const faqs = [
  {
    q: "Can we run Habitat OS in our own cloud account?",
    a: "Yes. Customer VPC and dedicated cloud-account deployments are standard. We provision with your infrastructure team, your IAM, and your network topology. On-prem is available for regulated workloads.",
  },
  {
    q: "Who owns the code and the data?",
    a: "You do. Your Habitat configuration, prompts, tools, and memory are your IP. Your operational data never leaves customer-controlled storage. If you stop the engagement, you keep everything — and because the core engine is open-source, you have continuity options.",
  },
  {
    q: "Can we bring our own model providers?",
    a: "Yes. Habitat OS routes to OpenAI, Anthropic, Google, AWS Bedrock, Azure OpenAI, and on-premise open-weight models (Ollama, vLLM). Customer-provided keys are the default. We can broker if you prefer a single invoice.",
  },
  {
    q: "How do you handle model provider outages?",
    a: "Habitat OS supports per-task fallback across providers. A critical invoice-processing step can default to GPT-5, fall back to Claude, and fail gracefully to a human-in-the-loop queue if both are degraded.",
  },
  {
    q: "What happens if we stop paying the Habitat OS Runtime?",
    a: "We help you migrate. Because the engine is open-source, you can continue to run the Habitat yourself or with another partner — you're never stranded. Our retention rate comes from the work being good, not from lock-in.",
  },
  {
    q: "Do you have SOC 2?",
    a: "Two answers — because there are two layers. Platform: our managed runtime is deployed on Vercel, which holds SOC 2 Type 2, ISO 27001:2022, PCI DSS Level 1, and supports HIPAA with a BAA. Those controls apply to the infrastructure your Habitat runs on. Program: TheFocus.AI's own SOC 2 Type I audit is underway for 2026. In the meantime, we provide security posture documentation, deployment-boundary diagrams, and data-handling practices to any serious evaluator under NDA. We'd rather be honest than check a box we haven't earned.",
  },
  {
    q: "Why Vercel?",
    a: "Because we didn't want to rebuild enterprise platform security from scratch while also delivering agent systems. Vercel gives us a platform with SOC 2 Type 2, ISO 27001:2022, PCI DSS, HIPAA support, Secure Compute (dedicated VPCs with static egress IPs), and a managed firewall with DDoS mitigation — already audited, already battle-tested. Our job is the Habitat runtime, the integrations, and the principal relationship. Everything below that, we inherit from a platform that's already trusted by teams with CISOs who don't accept \"we're working on it.\"",
  },
  {
    q: "How is pricing structured?",
    a: "Habitat OS Runtime starts at $2,000 per Habitat per month. Your first Habitat is delivered through a fixed-fee Build & Ship engagement (separate project cost). Volume pricing applies at 10+ Habitats, and custom arrangements are available for regulated industries.",
  },
  {
    q: "How is this different from LangChain, Bedrock Agents, or Copilot Studio?",
    a: "LangChain is a framework, not a managed runtime — you're on your own for security, identity, and operations. Hyperscaler agent platforms lock you to one vendor and don't carry your cross-SaaS tribal knowledge. Copilot Studio is Microsoft-shaped and Microsoft-operated. Habitat OS is a dedicated runtime for agents that carry your team's rules across whatever tools you actually use.",
  },
];
---

<BaseLayout
  pageTitle="Habitat OS — Enterprise Agent Platform | TheFocus.AI"
  description="Habitat OS is TheFocus.AI's enterprise agent runtime for new production AI builds. Runs in your cloud, on your terms, with named principal accountability and an open-source core."
  category="habitat-os"
  openGraphImage="og-habitat-os.png"
>
  <!-- Hero -->
  <div class="max-w-4xl mx-auto">
    <section class="py-8 md:py-16">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-6 font-medium">The enterprise runtime for production AI</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold mb-6 text-ink leading-tight">
        Habitat OS.<br/>Production AI,<br/>under your control.
      </h1>
      <p class="text-xl md:text-2xl text-graphite leading-relaxed mb-4 max-w-3xl">
        The enterprise runtime for every Habitat we build. Your cloud. Auditable core. Run by the principals who built it.
      </p>
      <p class="text-base text-graphite/70 mb-10 max-w-3xl">
        Built for CISOs who have said "no" to AI rollouts and are looking for the "yes" that doesn't cost them their standards.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={mailto}
          class="inline-block px-8 py-4 bg-petrol text-paper font-medium uppercase text-sm tracking-wider rounded-full hover:bg-petrol/90 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 text-center"
        >
          Talk to a principal
        </a>
        <a
          href="#architecture"
          class="inline-block px-8 py-4 border-2 border-ink/20 text-ink font-medium uppercase text-sm tracking-wider rounded-full hover:border-petrol hover:text-petrol hover:-translate-y-0.5 transition-all duration-200 text-center"
        >
          See the architecture
        </a>
      </div>
    </section>
  </div>

  <!-- What is a Habitat -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-tint-cool/30" id="architecture">
    <div class="max-w-4xl mx-auto px-5 md:px-8 py-16 md:py-24">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-4 font-medium">The Anatomy</p>
      <h2 class="text-3xl md:text-5xl font-bold text-ink mb-4">What is a Habitat?</h2>
      <p class="text-lg md:text-xl text-graphite mb-10 max-w-3xl leading-relaxed">
        A Habitat is the living environment for an agent. Not a wrapper around a prompt — a place where an agent exists. Persona, memory, tools, sessions, and sub-agents, all in one governed environment.
      </p>

      <!-- Anatomy diagram -->
      <div class="bg-paper border border-petrol/20 rounded-2xl p-6 md:p-10 mb-10">
        <div class="grid md:grid-cols-2 gap-8 md:gap-10">
          <div>
            <p class="text-xs font-mono text-petrol mb-2 font-bold uppercase tracking-wider">A Habitat contains</p>
            <ul class="space-y-4 mt-4">
              <li class="flex gap-3 items-start">
                <span class="text-petrol font-mono text-sm mt-1">01</span>
                <div>
                  <p class="font-bold text-ink">Persona</p>
                  <p class="text-sm text-graphite">Who the agent is, what it will and won't do, its authority boundaries.</p>
                </div>
              </li>
              <li class="flex gap-3 items-start">
                <span class="text-petrol font-mono text-sm mt-1">02</span>
                <div>
                  <p class="font-bold text-ink">Tools</p>
                  <p class="text-sm text-graphite">Typed interfaces to your SaaS, your databases, your internal APIs.</p>
                </div>
              </li>
              <li class="flex gap-3 items-start">
                <span class="text-petrol font-mono text-sm mt-1">03</span>
                <div>
                  <p class="font-bold text-ink">Memory</p>
                  <p class="text-sm text-graphite">Persistent institutional knowledge. Facts the agent has learned, decisions it's made, edge cases it's handled.</p>
                </div>
              </li>
            </ul>
          </div>
          <div>
            <p class="text-xs font-mono text-petrol mb-2 font-bold uppercase tracking-wider">And plugs into</p>
            <ul class="space-y-4 mt-4">
              <li class="flex gap-3 items-start">
                <span class="text-petrol font-mono text-sm mt-1">04</span>
                <div>
                  <p class="font-bold text-ink">Sub-agents</p>
                  <p class="text-sm text-graphite">Specialized workers the Habitat delegates to. Composable, not monolithic.</p>
                </div>
              </li>
              <li class="flex gap-3 items-start">
                <span class="text-petrol font-mono text-sm mt-1">05</span>
                <div>
                  <p class="font-bold text-ink">Sessions</p>
                  <p class="text-sm text-graphite">Every interaction logged, replayable, auditable. Your compliance team gets the paper trail.</p>
                </div>
              </li>
              <li class="flex gap-3 items-start">
                <span class="text-petrol font-mono text-sm mt-1">06</span>
                <div>
                  <p class="font-bold text-ink">Evals</p>
                  <p class="text-sm text-graphite">Automated quality checks against known-good behavior. Regressions surface before production does.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="bg-petrol/5 border-l-4 border-petrol rounded-r-2xl p-6 md:p-8">
        <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-2 font-medium">The two-level model</p>
        <p class="text-lg text-ink leading-relaxed">
          <strong>Habitat OS</strong> is the enterprise runtime. <strong>A Habitat</strong> is the agent environment your team actually uses. Your monthly close Habitat, your hiring Habitat, your reporting Habitat — every one of them runs on Habitat OS.
        </p>
      </div>
    </div>
  </div>

  <!-- Why Habitat OS -->
  <div class="max-w-4xl mx-auto">
    <section class="py-16 md:py-24">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-4 font-medium">Why Habitat OS</p>
      <h2 class="text-3xl md:text-5xl font-bold text-ink mb-4">Four commitments your security team can verify.</h2>
      <p class="text-lg text-graphite mb-12 max-w-3xl">
        Banks, private equity firms, healthcare systems, and real estate operators have told us the same thing: they want modern AI, but not if it means giving up sovereignty over their data, their infrastructure, or their accountability chain. Habitat OS is the answer.
      </p>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8">
        {pillars.map((pillar) => (
          <div class="bg-paper border border-ink/10 rounded-2xl p-6 md:p-8 hover:border-petrol/30 transition-all">
            <p class="text-xs uppercase tracking-[0.15em] text-petrol mb-3 font-medium">{pillar.eyebrow}</p>
            <h3 class="text-xl md:text-2xl font-bold text-ink mb-3 leading-tight">{pillar.title}</h3>
            <p class="text-graphite leading-relaxed">{pillar.body}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Habitat WorkStreams -->
  <div class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-tint-cool/30">
    <div class="max-w-6xl mx-auto px-5 md:px-8 py-16 md:py-24">
      <p class="text-xs uppercase tracking-[0.2em] text-petrol mb-4 font-medium">Habitat WorkStreams · The human layer</p>
      <h2 class="text-3xl md:text-5xl font-bold text-ink mb-4">Your best prompts shouldn't die in one person's chat history.</h2>
      <p class="text-lg text-graphite mb-4 max-w-3xl leading-relaxed">
        Every Habitat on Habitat OS has a WorkStream layer — the place where your people actually work with it. Private by default. Promotable on their terms. Discoverable when the artifact is ready for the rest of the org.
      </p>
      <p class="text-base text-graphite/80 mb-12 max-w-3xl leading-relaxed">
        The fast adopters stop racing away from the rest of the org. The skeptics get to watch before they participate. The work your best people do stops being lost when a tab closes, a laptop retires, or an employee moves on.
      </p>

      <!-- Three principles -->
      <div class="grid md:grid-cols-3 gap-4 md:gap-6 mb-16">
        {workstreamPrinciples.map((p) => (
          <div class="bg-paper border border-ink/10 rounded-2xl p-6 md:p-7 hover:border-petrol/30 transition-all">
            <p class="text-xs uppercase tracking-[0.15em] text-petrol mb-3 font-medium">{p.eyebrow}</p>
            <h3 class="text-lg md:text-xl font-bold text-ink mb-3 leading-tight">{p.title}</h3>
            <p class="text-sm text-graphite leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>

      <!-- Mockup: Stream feed + Popular sidebar -->
      <div
        class="bg-paper border border-ink/10 rounded-2xl p-5 md:p-8 mb-10 shadow-sm"
        role="region"
        aria-label="Example Habitat WorkStream"
      >
        <div class="flex items-center justify-between mb-6 pb-4 border-b border-ink/10 flex-wrap gap-3">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-petrol-light"></span>
            <p class="text-xs font-mono text-graphite uppercase tracking-wider">acme.habitats.ai / workstream · live view</p>
          </div>
          <span class="text-[10px] font-mono text-graphite/60 uppercase tracking-wider">Illustrative — not a live product screenshot</span>
        </div>

        <div class="grid lg:grid-cols-[1fr_320px] gap-6 lg:gap-8">
          <!-- Feed -->
          <div class="space-y-4 md:space-y-5">
            <p class="text-xs font-mono text-petrol uppercase tracking-wider mb-1">Today · your org</p>
            {workstreamFeed.map((card) => (
              <article class="border border-ink/10 rounded-xl p-5 bg-paper">
                <!-- Author row -->
                <div class="flex items-start gap-3 mb-3 flex-wrap">
                  <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-petrol-light text-paper text-sm font-bold shrink-0">
                    {card.initials}
                  </span>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-bold text-ink leading-tight">
                      {card.author} <span class="text-graphite/70 font-normal">· {card.role}</span>
                    </p>
                    <p class="text-[11px] font-mono text-petrol uppercase tracking-wider mt-0.5">{card.habitat}</p>
                  </div>
                </div>

                <!-- Prompt -->
                <div class="bg-tint-cool/40 border-l-2 border-petrol/40 rounded-r-md px-4 py-3 mb-3">
                  <p class="text-[10px] font-mono text-petrol uppercase tracking-wider mb-1">Prompt</p>
                  <p class="text-sm text-ink leading-relaxed">{card.prompt}</p>
                </div>

                <!-- Response -->
                <div class="pl-4 border-l-2 border-ink/10 mb-4">
                  <p class="text-[10px] font-mono text-graphite/70 uppercase tracking-wider mb-1">Habitat response</p>
