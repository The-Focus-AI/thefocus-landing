---
// You can pass props to customize or use site config
const {
  name = "TheFocus.AI",
  description = "AI consultancy that helps mid-market and enterprise organizations ship production AI in weeks, not quarters. From tribal knowledge to intelligent systems — Assessment & Roadmap, Build & Ship, and Ongoing Partnership engagements.",
  logo = "https://thefocus.ai/logo.png",
  foundingDate = "2024",
  socialProfiles = [
    "https://github.com/The-Focus-AI",
    "https://x.com/wschenk",
    "https://www.linkedin.com/in/will-schenk-420266/"
  ]
} = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": name,
  "description": description,
  "url": Astro.site,
  "foundingDate": foundingDate,
  "logo": new URL(logo, Astro.site).toString(),
  "sameAs": socialProfiles,
  "knowsAbout": ["Artificial Intelligence", "Machine Learning", "AI Strategy", "Production AI Systems", "Organizational AI Maturity", "Agentic AI"],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "24 Kent Rd South",
    "addressLocality": "Cornwall Bridge",
    "addressRegion": "CT",
    "postalCode": "06754",
    "addressCountry": "US"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "hey@thefocus.ai",
    "contactType": "customer service"
  },
  "founder": [
    {
      "@type": "Person",
      "name": "Ben Schippers",
      "jobTitle": "Co-Founder",
      "url": "https://thefocus.ai/about",
      "sameAs": "https://www.linkedin.com/in/benschippers/"
    },
    {
      "@type": "Person",
      "name": "Will Schenk",
      "jobTitle": "Co-Founder",
      "url": "https://thefocus.ai/about",
      "sameAs": "https://www.linkedin.com/in/will-schenk-420266/"
    }
  ]
};
---

<!-- Organization Schema -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />