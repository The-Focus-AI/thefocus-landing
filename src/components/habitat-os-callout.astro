---
// Shared "Built on Habitat OS" snippet. Used on offerings and related pages.
// Reinforces the two-level noun model: Habitat OS = platform, a Habitat = the deployed instance.
interface Props {
  variant?: "inline" | "card";
  lede?: string;
}
const { variant = "inline", lede } = Astro.props;
const defaultLede =
  "A Habitat is a production AI system that carries your team's rules, learns from decisions, and runs autonomously on Habitat OS — our enterprise runtime.";
const copy = lede ?? defaultLede;
---

{variant === "inline" ? (
  <div class="flex flex-col sm:flex-row sm:items-center gap-3 text-sm">
    <span class="inline-flex items-center gap-2 text-petrol font-medium shrink-0">
      <span class="w-2 h-2 rounded-full bg-petrol"></span>
      Built on Habitat OS
    </span>
    <span class="text-graphite leading-relaxed">{copy}</span>
    <a
      href="/habitat-os"
      class="text-petrol font-medium whitespace-nowrap hover:underline shrink-0"
    >
      Learn about the platform &rarr;
    </a>
  </div>
) : (
  <a
    href="/habitat-os"
    class="group block bg-petrol/5 border border-petrol/20 rounded-2xl p-5 md:p-6 hover:border-petrol/40 hover:bg-petrol/10 transition-all"
  >
    <div class="flex items-start gap-4">
      <div class="shrink-0 w-10 h-10 rounded-full bg-petrol/10 flex items-center justify-center">
        <span class="w-2.5 h-2.5 rounded-full bg-petrol"></span>
      </div>
      <div class="flex-1">
        <p class="text-xs uppercase tracking-[0.15em] text-petrol font-medium mb-1">Built on Habitat OS</p>
        <p class="text-sm md:text-base text-ink leading-relaxed mb-2">{copy}</p>
        <span class="text-sm text-petrol font-medium group-hover:underline">
          Learn about the platform &rarr;
        </span>
      </div>
    </div>
  </a>
)}
