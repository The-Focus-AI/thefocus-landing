---
// Shared "Built on Habitat OS" snippet. Used on offerings, case studies, and related pages.
// Reinforces the two-level noun model: Habitat OS = platform, a Habitat = the deployed instance.
//
// Variants:
//   - "chip":   Compact pill. Use inside dense sections (offering "How we fix this", case study headers).
//   - "card":   Prominent block with a lede. Use on capabilities/marketing surfaces where the
//               platform deserves explanation, not just attribution.
//
// "inline" is kept as an alias for "chip" for backwards compatibility with existing callers.
interface Props {
  variant?: "chip" | "card" | "inline";
  lede?: string;
}
const { variant = "chip", lede } = Astro.props;
const useChip = variant === "chip" || variant === "inline";
const defaultLede =
  "A Habitat is a production AI system that carries your team's rules, learns from decisions, and runs autonomously on Habitat OS — our enterprise runtime.";
const copy = lede ?? defaultLede;
---

{useChip ? (
  <a
    href="/habitat-os"
    class="inline-flex items-center gap-2 text-xs font-medium text-petrol bg-petrol/5 border border-petrol/20 px-3 py-1.5 rounded-full hover:bg-petrol/10 hover:border-petrol/40 transition-colors"
  >
    <span class="w-1.5 h-1.5 rounded-full bg-petrol"></span>
    Built on Habitat OS
    <span class="opacity-60">&rarr;</span>
  </a>
) : (
  <a
    href="/habitat-os"
    class="group block bg-petrol/5 border border-petrol/20 rounded-2xl p-5 md:p-6 hover:border-petrol/40 hover:bg-petrol/10 transition-all"
  >
    <div class="flex items-start gap-4">
      <div class="shrink-0 w-10 h-10 rounded-full bg-petrol/10 flex items-center justify-center">
        <span class="w-2.5 h-2.5 rounded-full bg-petrol"></span>
      </div>
      <div class="flex-1">
        <p class="text-xs uppercase tracking-[0.15em] text-petrol font-medium mb-1">Built on Habitat OS</p>
        <p class="text-sm md:text-base text-ink leading-relaxed mb-2">{copy}</p>
        <span class="text-sm text-petrol font-medium group-hover:underline">
          Learn about the platform &rarr;
        </span>
      </div>
    </div>
  </a>
)}
